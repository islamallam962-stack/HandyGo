## ============================================================
## .gitignore — HandyGo ASP.NET Core MVC
## ============================================================


# ============================================================
# [1] SECRETS — لا يتحملوا GitHub أبداً
# ============================================================
appsettings.json
appsettings.Development.json
appsettings.Production.json
secrets.json
.env
.env.*


# ============================================================
# [2] Build Output
# ============================================================
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/


# ============================================================
# [3] Visual Studio / Rider
# ============================================================
.vs/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
*.DotSettings.user


# ============================================================
# [4] .NET / NuGet
# ============================================================
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/
packages/
!**/[Pp]ackages/build/


# ============================================================
# [5] Publish Output
# ============================================================
**/publish/
**/PublishProfiles/
*.pubxml
*.pubxml.user


# ============================================================
# [6] Runtime & Temp Files
# ============================================================
*.tmp
*.temp
*.log
*.cache
*.bak
*.swp
~$*


# ============================================================
# [7] Node / Frontend
# ============================================================
node_modules/
npm-debug.log*
yarn-error.log*


# ============================================================
# [8] OS Files
# ============================================================
.DS_Store
Thumbs.db
desktop.ini


# ============================================================
# [9] User Uploaded Images (runtime generated)
# ============================================================
wwwroot/images/chat/
wwwroot/images/certificates/
wwwroot/images/profiles/
