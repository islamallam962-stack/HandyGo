                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show m-3 mb-0 rounded-4 shadow-sm" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show m-3 mb-0 rounded-4 shadow-sm" role="alert">
                <i class="bi bi-info-circle-fill me-2"></i>@TempData["Message"]
