</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>

    function validateFiles(input, isSingle = false) {
        const maxSize = 5 * 1024 * 1024; 
        
        if (!isSingle && input.files.length > 5) {
            alert("Š« Ū„ŖšŖ —›ŕ √Ŗň— „š 5 ’ś— ŖÕŌ √ř’ž ŠŇň»«  «ŠŚśŪ….");
            input.value = ""; 
            return;
        }

        for (let i = 0; i < input.files.length; i++) {
            if (input.files[i].size > maxSize) {
                alert("ÕŐ„ «Š’ś—… (" + input.files[i].name + ") Ū őōž 5 „ŪŐ«»«Ū ! Ū—Őž «ő Ū«— ’ś—… √’Ř—.");
                input.value = ""; 
                return;
            }
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });

        var activeTab = localStorage.getItem("activeTab");
        if (activeTab) {
            openTab(activeTab, true);
        }
    });

    function openTab(tabName, isLoad = false) {
        var contents = document.getElementsByClassName("tab-content");
        for (var i = 0; i < contents.length; i++) contents[i].classList.remove("active");

        var btns = document.getElementsByClassName("tab-btn");
        for (var i = 0; i < btns.length; i++) btns[i].classList.remove("active");

        var targetTab = document.getElementById(tabName);
        if (targetTab) {
            targetTab.classList.add("active");
        }

        if (!isLoad && window.event && window.event.currentTarget) {
            window.event.currentTarget.classList.add("active");
        } else {
            var btn = document.querySelector("button[onclick=\"openTab('" + tabName + "')\"]");
            if (btn) btn.classList.add("active");
        }

        localStorage.setItem("activeTab", tabName);
    }

    function toggleReportForm(requestId) {
        var form = document.getElementById('complaintContainer-' + requestId);
        form.style.display = (form.style.display === 'none' || form.style.display === '') ? 'block' : 'none';
    }

    function submitComplaintAjax(requestId) {
        var subject = document.getElementById('subject-' + requestId).value;
        var desc = document.getElementById('desc-' + requestId).value;
        var statusDiv = document.getElementById('status-' + requestId);
        
        if (!subject || !desc) { 
            alert("Please fill in both subject and description."); 
            return; 
        }

        $.ajax({
            url: '/Profile/SubmitComplaint',
            type: 'POST',
            data: { requestId: requestId, subject: subject, description: desc },
            success: function () {
                statusDiv.innerHTML = '<span class="text-success fw-bold small">? Submitted successfully.</span>';
                document.getElementById('subject-' + requestId).value = '';
                document.getElementById('desc-' + requestId).value = '';
                setTimeout(function() { 
                    toggleReportForm(requestId); 
                    statusDiv.innerHTML = ''; 
                }, 2500);
            },
            error: function () { 
                statusDiv.innerHTML = '<span class="text-danger small">? Error sending complaint.</span>'; 
            }
        });
    }
</script>
