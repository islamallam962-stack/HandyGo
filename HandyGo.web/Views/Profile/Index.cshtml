@model HandyGo.web.Models.User
@using Microsoft.AspNetCore.Http

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f4f7f6;
    }

    .profile-header {
        background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
        color: white;
        padding: 30px;
        border-radius: 15px 15px 0 0;
        margin-bottom: 0;
    }

    .main-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        border: none;
        overflow: hidden;
    }

    .nav-tabs-custom {
        display: flex;
        gap: 10px;
        background: #fff;
        padding: 15px 25px;
        border-bottom: 1px solid #edf2f7;
    }

    .tab-btn {
        padding: 10px 25px;
        border: none;
        background: #f8f9fa;
        cursor: pointer;
        border-radius: 10px;
        transition: 0.3s;
        font-weight: 600;
        color: #4a5568;
    }

    .tab-btn.active {
        background: #007bff;
        color: white;
        box-shadow: 0 4px 12px rgba(0,123,255,0.3);
    }

    .tab-content {
        display: none;
        padding: 30px;
        animation: fadeIn 0.4s ease;
    }

    .tab-content.active {
        display: block;
    }

    .profile-img {
        border: 5px solid white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

    .profile-info-item {
        padding: 12px;
        border-bottom: 1px solid #f1f1f1;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .upgrade-card {
        background: linear-gradient(145deg, #fdfdfe, #f4f7f6);
        border: 2px dashed #cbd5e1;
        transition: all 0.3s ease;
    }

    .upgrade-card:hover {
        border-color: #007bff;
        background: #f8fbff;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="container mt-5 mb-5">
    <div class="main-card">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-3 mb-0 rounded-4 shadow-sm" role="alert">
