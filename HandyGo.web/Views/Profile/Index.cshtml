                                            <strong><i class="bi bi-x-circle-fill me-1"></i>  „ —›÷ «Š√ś—«ř «Š”«»ř…:</strong> <br />
                                            <small>@Model.VerificationRejectionReason</small>
                                        </div>
                                    }

                                    <p class="text-muted small mb-4">
                                        «Šŕ„Š«Ń Ū›÷Šśš «Š›šŪŪš «Š„śňřŪš! ř„ »—›ŕ ’ś—… ś«÷Õ… Š»ō«ř Ŗ «Š‘ő’Ū… Š Õ’Š ŕŠž ‘«—… «Š śňŪř <i class="bi bi-patch-check-fill text-primary"></i> „Ő«š«ū.
                                    </p>
                                    
                                    <form asp-action="SubmitVerification" asp-controller="Profile" method="post" enctype="multipart/form-data">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold text-dark small">’ś— «Š»ō«ř… („š 1 ŇŠž 5 ’ś—) <span class="text-danger">*</span></label>
                                                <input type="file" name="idCards" class="form-control" accept="image/*" multiple required onchange="validateFiles(this)">
                                                <small class="text-muted d-block mt-1"><i class="bi bi-info-circle me-1"></i>ś‘ śŔŚ— (»ÕŌ √ř’ž 5 „ŪŐ« ŠŠ’ś—…)</small>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold text-dark small">«Š›Ū‘ «ŠŐš«∆Ū / ‘Ś«Ō… «ŠÕ—›… («ő Ū«—Ū)</label>
                                                <input type="file" name="certificate" class="form-control" accept="image/*" onchange="validateFiles(this, true)">
                                                <small class="text-muted d-block mt-1"><i class="bi bi-info-circle me-1"></i>»ÕŌ √ř’ž 5 „ŪŐ« ŠŠ’ś—…</small>
                                            </div>
                                            <div class="col-12 mt-4 text-end">
