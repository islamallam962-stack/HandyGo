@model HandyGo.web.Models.User
@using Microsoft.AspNetCore.Http

<style>
    body {
        background-color: #f8f9fa;
    }

    .profile-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow: hidden;
        margin-top: 30px;
    }

    .profile-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        height: 120px;
    }

    .profile-avatar-container {
        margin-top: -75px;
        text-align: center;
        position: relative;
    }

    .profile-avatar {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        border: 5px solid white;
        object-fit: cover;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    .status-badge {
        position: absolute;
        bottom: 10px;
        right: calc(50% - 65px);
        width: 25px;
        height: 25px;
        border-radius: 50%;
        border: 3px solid white;
    }

    .info-label {
        color: #6c757d;
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
    }

    .info-value {
        color: #2d3748;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .admin-box {
        border-radius: 15px;
        border: 2px dashed #dc3545;
        background-color: #fff5f5;
    }

    
    .modern-tag {
        display: inline-block;
        background: rgba(102, 126, 234, 0.1);
        color: #667eea;
        padding: 6px 16px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 700;
        margin-right: 8px;
        margin-bottom: 8px;
        border: 1px solid rgba(102, 126, 234, 0.2);
        transition: all 0.3s ease;
    }

        .modern-tag:hover {
            background: #667eea;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(102, 126, 234, 0.3);
        }

        .modern-tag.cert-tag {
            background: rgba(118, 75, 162, 0.1);
            color: #764ba2;
            border-color: rgba(118, 75, 162, 0.2);
        }

            .modern-tag.cert-tag:hover {
                background: #764ba2;
                color: white;
                box-shadow: 0 4px 10px rgba(118, 75, 162, 0.3);
            }
</style>

<div class="container py-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" style="max-width: 900px; margin: 0 auto;" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 shadow-sm" style="max-width: 900px; margin: 0 auto;" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    
    @if (Context.Session.GetString("UserRole") == "Admin")
    {
        <div class="admin-box p-4 mb-4 shadow-sm mx-auto" style="max-width: 900px;">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-danger text-white rounded-circle p-2 me-3">
                    <i class="bi bi-shield-lock-fill fs-4"></i>
                </div>
                <div>
                    <h5 class="mb-0 text-danger fw-bold">Admin Control Panel</h5>
                    <small class="text-muted">You are investigating this profile as an administrator.</small>
                </div>
            </div>

            <div class="row g-3 align-items-center">
                <div class="col-auto">
                    <form asp-controller="Admin" asp-action="ToggleUserStatus" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn @(Model.IsActive ? "btn-outline-danger" : "btn-success") px-4 shadow-sm">
                            <i class="bi @(Model.IsActive ? "bi-person-x" : "bi-person-check") me-2"></i>
                            @(Model.IsActive ? "Ban Account" : "Activate Account")
                        </button>
                    </form>
                </div>
                <div class="col">
                    <div class="input-group">
                        <span class="input-group-text bg-warning border-warning"><i class="bi bi-megaphone"></i></span>
                        <input type="text" id="warningMessageText" class="form-control border-warning" placeholder="Type a warning message..." required>
                        <button type="button" onclick="sendWarningAjax('@Model.Id')" class="btn btn-warning fw-bold">Send Warning</button>
                    </div>
                    <div id="warningAjaxStatus" class="mt-1 small fw-bold"></div>
                </div>
            </div>

            @if (!Model.IsActive)
            {
                <div class="alert alert-danger mt-3 mb-0 py-2">
                    <i class="bi bi-exclamation-octagon-fill me-2"></i> This account is currently <strong>Suspended</strong>.
                </div>
            }
        </div>
    }

    
    <div class="profile-card mx-auto" style="max-width: 900px;">
        <div class="profile-header"></div>

        <div class="profile-avatar-container">
            <img src="@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/default.png" : Model.ImagePath + "?v=" + DateTime.Now.Ticks)"
                 class="profile-avatar" alt="User Avatar" />
            <div class="status-badge @(Model.IsActive ? "bg-success" : "bg-danger")" title="@(Model.IsActive ? "Active" : "Banned")"></div>
        </div>

        <div class="p-4 text-center">
            <h2 class="fw-bold mb-1">@Model.Name</h2>
            <span class="badge rounded-pill @(Model.Role == "Technician" ? "bg-primary" : "bg-info") px-3 mb-4">
                @Model.Role
            </span>

            <hr class="my-4 opacity-25">

            <div class="row text-start px-md-5">
                <div class="col-md-6 mb-4">
                    <div class="info-label">Full Name</div>
                    <div class="info-value">@Model.Name</div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="info-label">Contact Number</div>
                    <div class="info-value">@(string.IsNullOrEmpty(Model.Phone) ? "Not provided" : Model.Phone)</div>
                </div>

                @if (Model.Role == "Technician")
                {
                    <div class="col-md-6 mb-4">
                        <div class="info-label">Specialization</div>
                        <div class="info-value text-primary">@Model.Category</div>
                    </div>

                    <div class="col-12 mb-4">
                        <div class="info-label mb-2">Professional Skills</div>
                        <div class="info-value">
                            @if (!string.IsNullOrEmpty(Model.Skills))
                            {
                                var skills = Model.Skills.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                foreach (var skill in skills)
                                {
                                    <span class="modern-tag"><i class="bi bi-check2-circle me-1"></i>@skill.Trim()</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted fst-italic" style="font-size: 0.95rem; font-weight: 400;">No skills provided yet.</span>
                            }
                        </div>
                    </div>

                    <div class="col-12 mb-4">
                        <div class="info-label mb-2">Certifications & Courses</div>
                        <div class="info-value">
                            @if (!string.IsNullOrEmpty(Model.Certificates))
                            {
                                var certs = Model.Certificates.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                foreach (var cert in certs)
                                {
                                    <span class="modern-tag cert-tag"><i class="bi bi-award-fill me-1"></i>@cert.Trim()</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted fst-italic" style="font-size: 0.95rem; font-weight: 400;">No certificates provided yet.</span>
                            }
                        </div>
                    </div>
                }
            </div>

            
            <div class="d-flex justify-content-center flex-wrap gap-3 mt-2">
                @if (Context.Session.GetInt32("UserId") != Model.Id)
                {
                    <form asp-controller="Chat" asp-action="StartChat" method="post">
                        <input type="hidden" name="otherUserId" value="@Model.Id" />
                        <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill shadow">
                            <i class="bi bi-chat-dots-fill me-2"></i> Open Chat
                        </button>
                    </form>

                    <button type="button" class="btn btn-outline-danger px-4 py-2 rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#reportModal">
                        <i class="bi bi-flag"></i> Report
                    </button>
                }
                else
                {
                    <a asp-action="Edit" class="btn btn-outline-secondary px-4 py-2 rounded-pill shadow-sm">
                        <i class="bi bi-gear me-2"></i> Edit My Profile
                    </a>
                }

                <button type="button" onclick="history.back()" class="btn btn-light border px-4 py-2 rounded-pill shadow-sm">
                    <i class="bi bi-arrow-left me-2"></i> Go Back
                </button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="reportModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i> Report User</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Profile" asp-action="SubmitReport" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="reportedUserId" value="@Model.Id" />
                    <p class="text-muted">Please describe the issue with <strong>@Model.Name</strong></p>
                    <textarea name="reason" class="form-control" rows="4" placeholder="Mention the issue clearly..." required></textarea>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger px-4">Submit Report</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function sendWarningAjax(userId) {
            var message = $('#warningMessageText').val();
            var statusDiv = $('#warningAjaxStatus');

            if (!message) {
                alert("Please type a message.");
                return;
            }

            $.ajax({
                url: '/Admin/SendWarning',
                type: 'POST',
                data: { id: userId, warningMessage: message },
                success: function () {
                    statusDiv.html('<span class="text-success">? Warning sent successfully!</span>');
                    $('#warningMessageText').val('');
                    setTimeout(function() { statusDiv.html(''); }, 3000);
                },
                error: function () {
                    statusDiv.html('<span class="text-danger">? Error sending warning.</span>');
                }
            });
        }
    </script>
}
