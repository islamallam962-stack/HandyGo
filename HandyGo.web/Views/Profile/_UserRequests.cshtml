@model HandyGo.web.Models.User

<style>
    .request-item-card {
        border: 1px solid #eef2f7;
        padding: 20px;
        margin-bottom: 20px;
        border-radius: 15px;
        background-color: #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        transition: 0.3s;
    }

        .request-item-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.07);
        }

    .stepper-wrapper {
        margin-top: 30px;
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
        position: relative;
    }

    .stepper-item {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        z-index: 1;
    }

        .stepper-item::before {
            position: absolute;
            content: "";
            border-bottom: 2px solid #e0e0e0;
            width: 100%;
            top: 20px;
            left: -50%;
            z-index: -1;
        }

        .stepper-item::after {
            position: absolute;
            content: "";
            border-bottom: 2px solid #e0e0e0;
            width: 100%;
            top: 20px;
            left: 50%;
            z-index: -1;
        }

        .stepper-item .step-counter {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #e0e0e0;
            margin-bottom: 6px;
            color: #fff;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .stepper-item.active .step-counter {
            background-color: #007bff;
            box-shadow: 0 0 10px rgba(0,123,255,0.4);
        }

        .stepper-item.completed .step-counter {
            background-color: #28a745;
        }

        .stepper-item.completed::after {
            border-bottom: 2px solid #28a745;
        }

        .stepper-item:first-child::before, .stepper-item:last-child::after {
            content: none;
        }

    .step-name {
        font-size: 11px;
        color: #777;
        font-weight: 500;
    }

    .active .step-name {
        color: #007bff;
        font-weight: bold;
    }

    .completed .step-name {
        color: #28a745;
    }
</style>

<div id="requestsTab" class="tab-content">
    <h3 class="fw-bold mb-4 text-dark"><i class="bi bi-activity me-2"></i>Active Orders</h3>

    @{
        var finishedStatuses = new[] { "Completed", "NotCompleted", "Rejected", "Closed" };
    }

    @foreach (var r in ViewBag.Requests)
    {

        if ((r.ClientId == Model.Id || r.TechnicianId == Model.Id) && !finishedStatuses.Contains((string)r.Status))
        {
            <div class="request-item-card">
                <div class="user-line" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <div style="display: flex; align-items: center;">
                        @if (Model.Role == "Client" && r.Technician != null)
                        {
                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@r.Technician.Id" class="d-flex align-items-center text-decoration-none text-dark">
                                <img src="@(r.Technician.ImagePath ?? "/images/default.png")" class="avatar clickable" style="width:50px; height:50px; border-radius:50%; margin-right:12px; object-fit: cover; border: 2px solid #eee;" />
                                <div>
                                    <small class="text-muted d-block">Technician</small>
                                    <strong class="text-primary">@r.Technician.Name</strong>
                                </div>
                            </a>
                        }
                        else if (Model.Role == "Technician" && r.Client != null)
                        {
                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@r.Client.Id" class="d-flex align-items-center text-decoration-none text-dark">
                                <img src="@(r.Client.ImagePath ?? "/images/default.png")" class="avatar clickable" style="width:50px; height:50px; border-radius:50%; margin-right:12px; object-fit: cover; border: 2px solid #eee;" />
                                <div>
                                    <small class="text-muted d-block">Client</small>
                                    <strong class="text-primary">@r.Client.Name</strong>
                                </div>
                            </a>
                        }
                    </div>

                    @if (Model.Role == "Client" && r.Status == "Pending")
                    {
                        <form asp-action="CancelRequest" asp-controller="Profile" method="post" onsubmit="return confirm('Are you sure?');">
                            <input type="hidden" name="requestId" value="@r.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                <i class="bi bi-trash"></i> Cancel
                            </button>
                        </form>
                    }
                </div>

                <div class="stepper-wrapper">
                    <div class="stepper-item @(r.Status == "Pending" ? "active" : "completed")">
                        <div class="step-counter"><i class="bi bi-file-earmark-text"></i></div>
                        <div class="step-name">Requested</div>
                    </div>
                    <div class="stepper-item @((r.Status == "Accepted" || r.Status == "WaitingForClientAcceptance" || r.Status == "PendingPayment" || r.Status == "PendingCard" || r.Status == "PendingCash") ? "active" : (r.Status == "InProgress" || r.Status == "PendingClientConfirmation" ? "completed" : ""))">
                        <div class="step-counter"><i class="bi bi-hand-thumbs-up"></i></div>
                        <div class="step-name">Accepted/Paid</div>
                    </div>
                    <div class="stepper-item @(r.Status == "InProgress" ? "active" : (r.Status == "PendingClientConfirmation" ? "completed" : ""))">
                        <div class="step-counter"><i class="bi bi-tools"></i></div>
                        <div class="step-name">In Progress</div>
                    </div>
                    <div class="stepper-item @(r.Status == "PendingClientConfirmation" ? "active" : "")">
                        <div class="step-counter"><i class="bi bi-check2-all"></i></div>
                        <div class="step-name">Finished</div>
                    </div>
                </div>

                <div style="background: #f8fbff; padding: 15px; border-radius: 12px; margin-top: 10px; border: 1px solid #e1e9f4;">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <p class="mb-1"><i class="bi bi-tools me-2 text-primary"></i><b>Service:</b> @r.ServiceType</p>
                            <p class="mb-0 text-muted"><i class="bi bi-geo-alt me-2 text-danger"></i><b>Location:</b> @r.Address</p>
                            @if (r.Price != null)
                            {
                                <p class="mb-0 mt-1 text-success"><i class="bi bi-cash me-2"></i><b>Price:</b> @r.Price EGP</p>
                            }
                        </div>
                        <div class="col-md-6 text-md-end mt-3 mt-md-0">
                            <span class="badge @(r.Status == "InProgress" ? "bg-primary" : "bg-warning text-dark") px-3 py-2 rounded-pill">
                                @r.Status
                            </span>
                            <div class="mt-2 small text-muted">@r.CreatedAt.ToString("g")</div>
                        </div>
                    </div>
                </div>

                @if (Model.Role == "Technician" && r.Status == "Accepted")
                {
                    <form action="/TechnicianRequests/StartService" method="post" class="mt-3">
                        <input type="hidden" name="id" value="@r.Id" />
                        <button type="submit" class="btn btn-success w-100 rounded-pill shadow-sm py-2">
                            <i class="bi bi-play-fill"></i> Start Service Now
                        </button>
                    </form>
                }
                
                @if (Model.Role == "Technician" && r.Status == "InProgress")
                {
                    <form action="/TechnicianRequests/FinishService" method="post" class="mt-3">
                        <input type="hidden" name="id" value="@r.Id" />
                        <div class="d-flex gap-2">
                            <button name="completed" value="true" class="btn btn-primary flex-grow-1 rounded-pill shadow-sm py-2">
                                <i class="bi bi-check-circle"></i> Mark Completed
                            </button>
                            <button name="completed" value="false" class="btn btn-outline-secondary flex-grow-1 rounded-pill py-2" onsubmit="return confirm('Are you sure?');">
                                Not Completed
                            </button>
                        </div>
                    </form>
                }

                @if (Model.Role == "Client" && r.Status == "PendingClientConfirmation")
                {
                    <div class="alert alert-warning mt-3 mb-2 p-2 small border-warning rounded-3 shadow-sm">
                        <i class="bi bi-info-circle-fill me-1"></i> The technician reported finishing the job. Please confirm to release funds.
                    </div>
                    
                    <form action="/OffersPrice/ConfirmServiceCompletion" method="post" class="mt-2" onsubmit="return confirm('Are you sure the service is completed satisfactorily? Funds will be released to the technician.');">
                        <input type="hidden" name="requestId" value="@r.Id" />
                        <button type="submit" class="btn btn-success w-100 fw-bold rounded-pill shadow-sm py-2">
                            <i class="bi bi-check-circle-fill me-1"></i> Confirm Completion & Release Funds
