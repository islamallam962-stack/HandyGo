<div id="historyTab" class="tab-content">
    <h3 class="fw-bold mb-4 text-dark"><i class="bi bi-clock-history me-2"></i>Service History</h3>

    @foreach (var r in ViewBag.Requests)
    {
        if (r != null && r.Technician != null && r.Client != null &&
        (r.ClientId == Model.Id || r.TechnicianId == Model.Id)
        && finishedStatuses.Contains((string)r.Status))
        {
            <div class="request-item-card border-start border-4 @(r.Status == "Completed" ? "border-success" : "border-secondary")">
                <div class="user-line mb-3 d-flex justify-content-between align-items-center">
                    <div>
                        @if (Model.Role == "Client")
                        {
                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@r.Technician.Id" class="d-flex align-items-center text-decoration-none text-dark">
                                <img src="@(r.Technician.ImagePath ?? "/images/default.png")" class="avatar clickable" style="width:45px; height:45px; border-radius:50%; margin-right:12px; object-fit: cover; border:1px solid #ddd;" />
                                <span><small class="text-muted d-block">Technician</small><b>@r.Technician.Name</b></span>
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@r.Client.Id" class="d-flex align-items-center text-decoration-none text-dark">
                                <img src="@(r.Client.ImagePath ?? "/images/default.png")" class="avatar clickable" style="width:45px; height:45px; border-radius:50%; margin-right:12px; object-fit: cover; border:1px solid #ddd;" />
                                <span><small class="text-muted d-block">Client</small><b>@r.Client.Name</b></span>
                            </a>
                        }
                    </div>
                    <span class="badge @(r.Status == "Completed" ? "bg-success" : "bg-secondary") px-3 rounded-pill">@r.Status</span>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <p class="mb-1 fw-bold">@r.ServiceType</p>
                        <p class="mb-1 text-muted small"><i class="bi bi-geo-alt"></i> @r.Address</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <small class="text-muted">Request Date: @r.CreatedAt.ToString("MMM dd, yyyy")</small>
                    </div>
                </div>

                @if (r.Status == "Completed")
                {
                    <div style="background: #f8f9fa; padding: 12px; border-radius: 12px; border-left: 4px solid #28a745;">
                        <div class="row text-center">
                            <div class="col-6 border-end">
                                <small class="text-muted d-block">Started:</small>
                                <span class="fw-bold small text-primary"><i class="bi bi-play-circle"></i> @(r.ActualStartTime != null ? r.ActualStartTime.ToString("h:mm tt") : r.CreatedAt.ToString("h:mm tt"))</span>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">Finished:</small>
                                <span class="fw-bold small text-success"><i class="bi bi-check-circle"></i> @(r.UpdatedAt.Year > 1 ? r.UpdatedAt.ToString("h:mm tt") : "N/A")</span>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.Role == "Client" && r.Status == "Completed")
                {
                    <div style="margin-top: 15px; padding-top: 15px; border-top: 1px dashed #eee;">
                        @if (r.Review != null)
                        {
                            <div style="background: #fffdf5; padding: 12px; border-radius: 8px; border: 1px solid #ffecb5;">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <h6 class="text-success small fw-bold mb-0"><i class="bi bi-star-fill"></i> Your Review</h6>
                                    <div class="text-warning">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi @(i <= r.Review.Stars ? "bi-star-fill" : "bi-star")"></i>
                                        }
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(r.Review.Comment))
                                {
                                    <p class="mb-0 small text-dark fst-italic">"@r.Review.Comment"</p>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="small fw-bold mb-0">Rate this technician:</h6>
                                <button type="button" class="btn btn-sm btn-link text-danger p-0 text-decoration-none" onclick="toggleReportForm('@r.Id')">
                                    <i class="bi bi-exclamation-triangle"></i> Report Issue
                                </button>
                            </div>
                            <form action="/Profile/SubmitReview" method="post" class="row g-2">
                                <input type="hidden" name="RequestId" value="@r.Id" />
                                <input type="hidden" name="TechId" value="@r.TechnicianId" />
                                <div class="col-sm-4">
                                    <select name="Stars" class="form-select form-select-sm">
                                        <option value="5">????? Excellent</option>
                                        <option value="4">???? Good</option>
                                        <option value="3">??? Average</option>
                                        <option value="2">?? Fair</option>
                                        <option value="1">? Poor</option>
                                    </select>
                                </div>
                                <div class="col-sm-6">
                                    <input type="text" name="Comment" class="form-control form-control-sm" placeholder="Any comments?" />
                                </div>
                                <div class="col-sm-2">
                                    <button type="submit" class="btn btn-warning btn-sm w-100 fw-bold">Rate</button>
                                </div>
                            </form>
                        }
                        <div id="complaintContainer-@r.Id" style="display:none;" class="mt-3 p-3 border rounded bg-light">
                            <h6 class="text-danger fw-bold small mb-2">Submit a Complaint</h6>
                            <input type="text" id="subject-@r.Id" class="form-control form-control-sm mb-2" placeholder="Issue Subject" />
                            <textarea id="desc-@r.Id" class="form-control form-control-sm mb-2" placeholder="Describe what happened..."></textarea>
                            <div id="status-@r.Id"></div>
                            <button type="button" onclick="submitComplaintAjax('@r.Id')" class="btn btn-danger btn-sm px-4">Submit Complaint</button>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<script>
    function setStars(element) {
        let allStars = element.parentElement.querySelectorAll('label');
        allStars.forEach(s => s.style.color = '#ccc');
        element.style.color = '#ffc107';
        let prev = element.nextElementSibling;
        while(prev && prev.tagName === 'LABEL') {
            prev.style.color = '#ffc107';
            prev = prev.nextElementSibling;
        }
        let next = element.previousElementSibling;
        while(next && next.tagName === 'LABEL') {
            next.style.color = '#ccc';
            next = next.previousElementSibling;
        }
    }
</script>
