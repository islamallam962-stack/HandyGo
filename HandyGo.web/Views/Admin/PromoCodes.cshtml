@model List<HandyGo.web.Models.PromoCode>
@{
    ViewData["Title"] = "إدارة الكوبونات والخصومات";
}

<div class="container py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm rounded-4 mb-4"><i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm rounded-4 mb-4"><i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1"><i class="bi bi-ticket-perforated text-primary me-2"></i> كوبونات الخصم</h2>
            <p class="text-muted mb-0 small">إنشاء وإدارة أكواد الخصم للعملاء لزيادة المبيعات.</p>
        </div>
        <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" data-bs-toggle="collapse" data-bs-target="#addPromoForm">
            <i class="bi bi-plus-lg me-1"></i> كود جديد
        </button>
    </div>

    <div class="collapse mb-4" id="addPromoForm">
        <div class="card border-0 shadow-sm rounded-4 bg-light">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="bi bi-magic text-warning me-2"></i> إصدار كود خصم جديد</h6>
                <form asp-action="CreatePromoCode" method="post">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">نص الكود (مثال: KHALED20)</label>
                            <input type="text" name="Code" class="form-control text-uppercase" required placeholder="أدخل الكود...">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">نوع الخصم</label>
                            <select name="DiscountType" class="form-select">
                                <option value="Percentage">نسبة مئوية (%)</option>
                                <option value="Fixed">مبلغ ثابت (ج.م)</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold">القيمة</label>
                            <input type="number" name="DiscountValue" class="form-control" required min="1" placeholder="مثال: 20">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold">الحد الأقصى للاستخدام</label>
                            <input type="number" name="MaxUsageCount" class="form-control" value="100" required min="1">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold">تاريخ الانتهاء</label>
                            <input type="date" name="ExpiryDate" class="form-control" required>
                        </div>
                        <div class="col-12 text-end mt-4">
                            <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold">إصدار الكود الآن</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="py-3 px-4">الكود</th>
                                <th class="py-3 text-center">نوع وقيمة الخصم</th>
                                <th class="py-3 text-center">الاستخدام</th>
                                <th class="py-3 text-center">تاريخ الانتهاء</th>
                                <th class="py-3 text-center">الحالة</th>
                                <th class="py-3 text-center">إجراء</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var promo in Model)
                            {
                                var isExpired = promo.ExpiryDate < DateTime.Now;
                                var isFullyUsed = promo.CurrentUsageCount >= promo.MaxUsageCount;

                                <tr>
                                    <td class="px-4">
                                        <span class="badge bg-dark fs-6 px-3 py-2 rounded-pill font-monospace shadow-sm">@promo.Code</span>
                                    </td>
                                    <td class="text-center fw-bold">
                                        @if (promo.DiscountType == "Percentage")
                                        {
                                            <span class="text-primary"><i class="bi bi-percent me-1"></i> @promo.DiscountValue%</span>
                                        }
                                        else
                                        {
                                            <span class="text-success"><i class="bi bi-cash me-1"></i> @promo.DiscountValue ج.م</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="small fw-bold @(isFullyUsed ? "text-danger" : "text-muted")">
                                            @promo.CurrentUsageCount / @promo.MaxUsageCount
                                        </div>
                                        <div class="progress mt-1" style="height: 5px;">
                                            <div class="progress-bar @(isFullyUsed ? "bg-danger" : "bg-primary")" role="progressbar" style="width: @((promo.CurrentUsageCount * 100) / promo.MaxUsageCount)%;"></div>
                                        </div>
                                    </td>
                                    <td class="text-center small fw-bold @(isExpired ? "text-danger" : "text-muted")">
                                        @promo.ExpiryDate.ToString("yyyy-MM-dd")
                                        @if (isExpired)
                                        {
                                            <br>
                                            <span class="badge bg-danger mt-1">منتهي</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (promo.IsActive && !isExpired && !isFullyUsed)
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill"><i class="bi bi-check-circle me-1"></i> نشط</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary px-3 py-2 rounded-pill"><i class="bi bi-x-circle me-1"></i> غير متاح</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <form asp-action="TogglePromoCode" method="post">
                                            <input type="hidden" name="id" value="@promo.Id" />
                                            @if (promo.IsActive)
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3" title="إيقاف الكود">إيقاف</button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-success rounded-pill px-3" title="تفعيل الكود">تفعيل</button>
                                            }
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center p-5">
                    <i class="bi bi-ticket-detailed text-muted opacity-50" style="font-size: 5rem;"></i>
                    <h5 class="mt-3 fw-bold text-muted">لا توجد أكواد خصم حالياً</h5>
                    <p class="text-muted small">اضغط على "كود جديد" بالأعلى لإنشاء أول كود خصم.</p>
                </div>
            }
        </div>
    </div>
</div>
