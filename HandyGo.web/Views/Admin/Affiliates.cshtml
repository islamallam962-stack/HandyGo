@model List<HandyGo.web.Models.User>
@{
    ViewData["Title"] = "لوحة متابعة المسوقين";
    var allUsers = ViewBag.AllUsers as List<HandyGo.web.Models.User>;
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1"><i class="bi bi-diagram-3-fill text-primary me-2"></i> لوحة المسوقين والدعوات</h2>
            <p class="text-muted mb-0 small">تابع نشاط المسوقين، عدد المدعوين، والمكافآت المستحقة.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="py-3 px-4">المسوق (صاحب الكود)</th>
                                <th class="py-3 text-center">كود الدعوة</th>
                                <th class="py-3 text-center">إجمالي المدعوين</th>
                                <th class="py-3 text-center" style="width: 25%;">فنيين موثقين (الهدف: 5)</th>
                                <th class="py-3 text-center">أرباحه المتوقعة</th>
                                <th class="py-3 text-center">التفاصيل</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var marketer in Model)
                            {

                                var invitedUsers = allUsers.Where(u => u.ReferredByUserId == marketer.Id).ToList();

                                var verifiedTechs = invitedUsers.Count(u => u.Role == "Technician" && u.VerificationStatus == "Verified" && !string.IsNullOrEmpty(u.CertificateImage));

                                int rewardCount = verifiedTechs / 5;
                                int totalEarned = rewardCount * 500;

                                int progress = verifiedTechs % 5;
                                int progressPercent = (progress * 100) / 5;

                                <tr>
                                    <td class="px-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@(marketer.ImagePath ?? "/images/default.png")" class="rounded-circle me-3 border" width="45" height="45" style="object-fit:cover;">
                                            <div>
                                                <h6 class="fw-bold mb-0 text-dark">@marketer.Name</h6>
                                                <small class="text-muted">@marketer.Role</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-dark px-3 py-2 rounded-pill font-monospace fs-6">@marketer.ReferralCode</span>
                                    </td>
                                    <td class="text-center fw-bold text-secondary fs-5">
                                        @invitedUsers.Count <i class="bi bi-people-fill small"></i>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-between small fw-bold mb-1">
                                            <span class="text-primary">الموثقين: @verifiedTechs</span>
                                            <span class="text-muted">الهدف: 5</span>
                                        </div>
                                        <div class="progress rounded-pill shadow-sm" style="height: 10px;">
                                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar" style="width: @progressPercent%;"></div>
                                        </div>
                                        <small class="text-muted" style="font-size: 10px;">باقي @(5 - progress) للمكافأة القادمة</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-bold text-success fs-5">@totalEarned <small>ج.م</small></span>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#invitedModal-@marketer.Id">
                                            <i class="bi bi-eye"></i> عرض المدعوين
                                        </button>
                                    </td>
                                </tr>

                                <div class="modal fade" id="invitedModal-@marketer.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered">
                                        <div class="modal-content border-0 shadow rounded-4">
                                            <div class="modal-header bg-light border-0">
                                                <h6 class="modal-title fw-bold"><i class="bi bi-people text-primary me-2"></i> الأشخاص الذين دعاهم (@marketer.Name)</h6>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body p-0">
                                                <ul class="list-group list-group-flush">
                                                    @foreach (var user in invitedUsers)
                                                    {
                                                        <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                                                            <div>
                                                                <h6 class="fw-bold mb-0">@user.Name</h6>
                                                                <small class="text-muted">@(user.Role == "Technician" ? "فني - " + user.Category : "عميل")</small>
                                                            </div>
                                                            @if (user.VerificationStatus == "Verified")
                                                            {
                                                                <span class="badge bg-success rounded-pill"><i class="bi bi-patch-check-fill me-1"></i> موثق</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-warning text-dark rounded-pill"><i class="bi bi-hourglass-split me-1"></i> غير موثق</span>
                                                            }
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center p-5">
                    <i class="bi bi-diagram-3 text-muted opacity-50" style="font-size: 5rem;"></i>
                    <h5 class="mt-3 fw-bold text-muted">لا يوجد مسوقين حتى الآن</h5>
                    <p class="text-muted small">بمجرد أن يستخدم شخص كود دعوة، سيظهر المسوق هنا.</p>
                </div>
            }
        </div>
    </div>
</div>
