@model List<HandyGo.web.Models.User>
@using HandyGo.web.Models

@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4 border-primary shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-megaphone"></i> Send Public Announcement</h5>
        </div>
        <div class="card-body">
            <div class="input-group">
                <input type="text" id="globalMessage" class="form-control" placeholder="Type your announcement here..." required>
                <button type="button" onclick="sendGlobalAjax()" class="btn btn-primary">
                    <i class="bi bi-send"></i> Send to All Users
                </button>
            </div>
            <div id="globalMessageStatus" class="mt-2 small fw-bold"></div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-lg-8">
            <h5 class="mb-4 text-secondary"><i class="bi bi-calendar3"></i> Performance Timeline</h5>
            <div class="row g-3">
                @foreach (var period in new[] { ("Today", "Today"), ("Week", "Week"), ("Month", "Month") })
                {
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm p-3">
                            <div class="text-muted small mb-2">@period.Item1</div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="h4 mb-0 text-dark">@ViewBag.Stats[period.Item2 + "Total"]</span>
                                <span class="text-success small">Done: @ViewBag.Stats[period.Item2 + "Done"]</span>
                            </div>
                            <div class="progress mt-2" style="height: 4px;">
                                @{
                                    var tTotal = (int)ViewBag.Stats[period.Item2 + "Total"];
                                    var tDone = (int)ViewBag.Stats[period.Item2 + "Done"];
                                    var rate = tTotal > 0 ? (tDone * 100 / tTotal) : 0;
                                }
                                <div class="progress-bar bg-success" style="width: @rate%"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <h5 class="mb-4 text-primary"><i class="bi bi-trophy"></i> Site Stars</h5>
            <div class="list-group shadow-sm">
                @if (ViewBag.TopTechnicians != null)
                {
                    foreach (var tech in ViewBag.TopTechnicians)
                    {
                        <div class="list-group-item border-0 p-3 mb-2 shadow-sm rounded d-flex align-items-center justify-content-between">
                            <div>
                                <div class="fw-bold">@tech.Name</div>
                                <small class="text-muted">@tech.Category</small>
                            </div>
                            <span class="badge bg-primary rounded-pill">@tech.RequestCount Requests</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <h2 class="mb-4">User Management</h2>
    <div class="table-responsive shadow-sm rounded bg-white">
        <table class="table table-hover text-center align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>User</th>
                    <th>Role</th>
                    <th>Last Seen</th>
                    <th>Activity</th>
                    <th>Rating</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-start ps-3">
                            <div class="fw-bold">@user.Name</div>
                            <small class="text-muted">@user.Email</small>
                        </td>
                        <td><span class="badge bg-secondary">@user.Role</span></td>
                        <td><small>@(user.LastSeen.HasValue? user.LastSeen.Value.ToString("g") : "-")</small></td>
                        <td>
                            @if (user.Role == "Technician")
                            {
                                <div class="small">Done: <b class="text-success">@(user.TechnicianRequests?.Count(r => r.Status == "Completed") ?? 0)</b></div>
                            }
                        </td>
                        <td>
                            @if (user.Role == "Technician")
                            {
                                var avg = user.ReceivedReviews?.Any() == true ? user.ReceivedReviews.Average(r => r.Stars) : 0;
                                <span class="text-warning fw-bold">@(avg > 0 ? avg.ToString("0.0") + " ?" : "-")</span>
                            }
                        </td>
                        <td>
                            @if (user.Role == "Technician")
                            {
                                <form asp-action="ToggleTopRated" asp-route-id="@user.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm @(user.IsTopRated ? "btn-warning" : "btn-outline-success")">
                                        @(user.IsTopRated ? "? Featured" : "Regular")
                                    </button>
                                </form>
                            }
                        </td>
                        <td>
                            <div class="d-flex justify-content-center gap-1">
                                <a asp-action="@(user.IsActive ? "BlockUser" : "UnblockUser")" asp-route-id="@user.Id" class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                    <i class="bi @(user.IsActive ? "bi-slash-circle" : "bi-check-circle")"></i>
                                </a>
                                <a asp-action="DeleteUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to permanently delete this user?');"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <hr class="my-5" />

    <div class="card shadow-sm border-0 mb-5">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0"><i class="bi bi-shield-exclamation"></i> Dispute & Complaint Center</h5>
        </div>
        <div class="card-body">
            <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#pills-reviews">Negative Reviews</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="pill" data-bs-target="#pills-complaints">Official Complaints</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="pill" data-bs-target="#pills-reports">Handle Reports</button>
                </li>
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="pills-reviews">
                    <table class="table align-middle">
                        <thead class="table-light"><tr><th>Client</th><th>Technician</th><th>Rating</th><th>Action</th></tr></thead>
                        <tbody>
                            @if (ViewBag.NegativeReviews != null)
                            {
                                foreach (var r in (List<Review>)ViewBag.NegativeReviews)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@r.Request.ClientId" class="text-decoration-none text-dark d-flex align-items-center">
                                                <img src="@(r.Request.Client.ImagePath ?? "/images/default.png")" style="width:35px; height:35px; border-radius:50%; object-fit:cover; margin-right:8px;" />
                                                <small class="fw-bold">@r.Request.Client.Name</small>
                                            </a>
                                        </td>
                                        <td>
                                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@r.Request.TechnicianId" class="text-decoration-none text-dark d-flex align-items-center">
                                                <img src="@(r.Request.Technician.ImagePath ?? "/images/default.png")" style="width:35px; height:35px; border-radius:50%; object-fit:cover; margin-right:8px;" />
                                                <small class="fw-bold">@r.Request.Technician.Name</small>
                                            </a>
                                        </td>
                                        <td class="text-warning">@r.Stars ?</td>
                                        <td>
                                            <button class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#warningModal" onclick="setWarningTarget('@r.Request.TechnicianId', '@r.Request.Technician.Name')">Warn Technician</button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="tab-pane fade" id="pills-complaints">
                    @if (ViewBag.OfficialComplaints != null)
                    {
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Complainant (Client)</th>
                                    <th>Against (Technician)</th>
                                    <th>Complaint Details</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in (List<Complaint>)ViewBag.OfficialComplaints)
                                {
                                    <tr id="complaint-@c.Id">
                                        <td>
                                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@c.Request.ClientId" class="text-decoration-none text-dark d-flex align-items-center">
                                                <img src="@(c.Request.Client.ImagePath ?? "/images/default.png")" style="width:35px; height:35px; border-radius:50%; object-fit:cover; margin-right:8px;" />
                                                <small class="fw-bold">@c.Request.Client.Name</small>
                                            </a>
                                        </td>
                                        <td>
                                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@c.Request.TechnicianId" class="text-decoration-none text-dark d-flex align-items-center">
                                                <img src="@(c.Request.Technician.ImagePath ?? "/images/default.png")" style="width:35px; height:35px; border-radius:50%; object-fit:cover; margin-right:8px;" />
                                                <small class="fw-bold">@c.Request.Technician.Name</small>
                                            </a>
                                        </td>
                                        <td>
                                            <div class="small">
                                                <strong class="text-danger">@c.Subject</strong><br />
                                                <span class="text-muted">@c.Description</span><br />
                                                <small class="text-secondary">@c.CreatedAt.ToString("g")</small>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-sm btn-dark" onclick="resolveAction('@c.Id', 'complaint')">Resolved</button>
                                                <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#warningModal" onclick="setWarningTarget('@c.Request.TechnicianId', '@c.Request.Technician.Name')">Warning</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="tab-pane fade" id="pills-reports">
                    <table class="table align-middle mt-3">
                        <thead class="table-light"><tr><th>From (Reporter)</th><th>Against (User)</th><th>Reason</th><th>Action</th></tr></thead>
                        <tbody>
                            @if (ViewBag.UserReports != null)
                            {
                                foreach (var report in (List<HandyGo.web.Models.UserReport>)ViewBag.UserReports)
                                {
                                    <tr id="report-@report.Id">
                                        <td>
                                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@report.ReporterId" class="text-decoration-none text-dark d-flex align-items-center">
                                                <img src="@(report.Reporter?.ImagePath ?? "/images/default.png")" style="width:35px; height:35px; border-radius:50%; object-fit:cover; margin-right:8px;" />
                                                <small class="fw-bold">@report.Reporter?.Name</small>
                                            </a>
                                        </td>
                                        <td>
                                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@report.ReportedUserId" class="text-decoration-none text-dark d-flex align-items-center">
                                                <img src="@(report.ReportedUser?.ImagePath ?? "/images/default.png")" style="width:35px; height:35px; border-radius:50%; object-fit:cover; margin-right:8px;" />
                                                <small class="fw-bold text-danger">@report.ReportedUser?.Name</small>
                                            </a>
                                        </td>
                                        <td><small>@report.Reason</small></td>
                                        <td>
                                            <div class="btn-group">
                                                <button class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#warningModal" onclick="setWarningTarget('@report.ReportedUserId', '@report.ReportedUser?.Name')">Warning</button>
                                                <a href="/Profile/Details/@report.ReportedUserId" class="btn btn-sm btn-info text-white">Inspect</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="warningModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Send Warning to: <span id="targetNameDisplay"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="targetId">
                <label class="mb-2">Warning Message Text:</label>
                <textarea id="warningMsg" class="form-control" rows="4" placeholder="Write the warning reason here..."></textarea>
                <div id="modalStatus" class="mt-2"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" onclick="submitWarning()" class="btn btn-danger">Send Now</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function setWarningTarget(id, name) {
            document.getElementById('targetId').value = id;
            document.getElementById('targetNameDisplay').innerText = name;
            document.getElementById('warningMsg').value = '';
            document.getElementById('modalStatus').innerHTML = '';
        }

        function submitWarning() {
            var id = document.getElementById('targetId').value;
            var msg = document.getElementById('warningMsg').value;

            if (!msg) { alert("Please write a message"); return; }

            $.ajax({
                url: '/Admin/TakeAction',
                type: 'POST',
                data: { techId: id, message: msg },
                success: function() {
                    document.getElementById('modalStatus').innerHTML = '<div class="alert alert-success">Warning sent successfully</div>';
                    setTimeout(() => { $('#warningModal').modal('hide'); }, 1000);
                },
                error: function() { alert("Error in sending"); }
            });
        }

        function resolveAction(id, type) {
            if (confirm("Are you sure you want to mark this complaint as resolved?")) {
                $.post('/Admin/ResolveComplaint/' + id, function() {
                    $('#' + type + '-' + id).fadeOut(300, function() { $(this).remove(); });
                }).fail(function() {
                    alert("Error marking as resolved.");
                });
            }
        }

        function sendGlobalAjax() {
            var msg = document.getElementById('globalMessage').value;
            var statusDiv = document.getElementById('globalMessageStatus');

            if (!msg) { alert("Please type an announcement."); return; }

            $.ajax({
                url: '/Admin/SendGlobalNotification',
                type: 'POST',
                data: { message: msg },
                success: function() {
                    statusDiv.innerHTML = '<span class="text-success"><i class="bi bi-check-circle"></i> Sent successfully to all users!</span>';
                    document.getElementById('globalMessage').value = '';
                    setTimeout(() => { statusDiv.innerHTML = ''; }, 3000);
                },
                error: function() {
                    statusDiv.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle"></i> Error sending announcement.</span>';
                }
            });
        }
    </script>
}
