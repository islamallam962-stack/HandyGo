@model List<HandyGo.web.Models.Request>

@{
    ViewData["Title"] = "Available Open Jobs";
}

<style>
    body {
        background-color: #f8f9fa;
    }

    .job-card {
        background: white;
        border: none;
        border-radius: 15px;
        transition: 0.3s;
        overflow: hidden;
    }

        .job-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.1) !important;
        }

    .client-img {
        width: 50px;
        height: 50px;
        border-radius: 10px;
        object-fit: cover;
    }

    .price-input-group {
        background: #f1f5f9;
        padding: 15px;
        border-radius: 12px;
    }

    .btn-send-offer {
        background: linear-gradient(135deg, #28a745 0%, #218838 100%);
        border: none;
        font-weight: bold;
        padding: 10px;
        border-radius: 8px;
    }

    .section-title {
        border-left: 5px solid #007bff;
        padding-left: 15px;
        margin-bottom: 25px;
    }
</style>

<div class="container py-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 rounded-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4 rounded-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div class="section-title mb-0">
            <h2 class="fw-bold mb-0">Available Jobs</h2>
            <p class="text-muted mb-0">Browse and apply for requests in your specialty</p>
        </div>
        <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to Profile
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-briefcase text-muted opacity-25" style="font-size: 4rem;"></i>
            <h4 class="mt-3 text-muted">No open jobs found</h4>
            <p>Check back later for new opportunities in your area.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-lg-6 mb-4">
                    <div class="card job-card shadow-sm h-100">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="d-flex align-items-center">
                                    <a asp-controller="Profile" asp-action="Details" asp-route-id="@item.ClientId">
                                        <img src="@(string.IsNullOrEmpty(item.Client.ImagePath) ? "/images/default.png" : item.Client.ImagePath)"
                                             class="client-img border me-3" alt="@item.Client.Name">
                                    </a>
                                    <div>
                                        <h6 class="mb-0 fw-bold">
                                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@item.ClientId" class="text-dark text-decoration-none hover-primary">
                                                @item.Client.Name
                                            </a>
                                        </h6>
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i> @item.CreatedAt.ToString("MMM dd, hh:mm tt")</small>
                                    </div>
                                </div>
                                <span class="badge bg-light text-primary border border-primary px-3 rounded-pill">@item.ServiceType</span>
                            </div>

                            <div class="mb-4">
                                <div class="d-flex align-items-center text-dark mb-2">
                                    <i class="bi bi-geo-alt-fill text-danger me-2"></i>
                                    <span class="fw-medium">@item.Address</span>
                                </div>
                            </div>

                            <hr class="opacity-10">

                            <form asp-action="SubmitBid" method="post" class="bid-form">
                                <input type="hidden" name="RequestId" value="@item.Id" />

                                <div class="price-input-group">
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <label class="small fw-bold text-muted mb-1">Your Price (EGP)</label>
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-cash-stack"></i></span>
                                                <input type="number" name="Price" class="form-control border-start-0 price-input" placeholder="0.00" min="1" step="0.5" required />
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <label class="small fw-bold text-muted mb-1">Delivery Time</label>
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-stopwatch"></i></span>
                                                <input type="text" name="EstimatedTime" class="form-control border-start-0" placeholder="e.g. 3 hours" required />
                                            </div>
                                        </div>
                                        <div class="col-12 mt-2">
                                            <label class="small fw-bold text-muted mb-1">Offer Details</label>
                                            <textarea name="Note" class="form-control form-control-sm" rows="2" placeholder="Tell the client why they should pick you..."></textarea>
                                        </div>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-success btn-send-offer w-100 mt-3 shadow-sm">
                                    <i class="bi bi-send-fill me-2"></i> Submit My Offer
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>

        document.querySelectorAll('.bid-form').forEach(form => {
            form.addEventListener('submit', function (e) {
                const priceInput = this.querySelector('.price-input');
                if (parseFloat(priceInput.value) <= 0) {
                    e.preventDefault();
                    alert("Please enter a valid price greater than zero.");
                    return;
                }

                if (!confirm("Are you sure you want to submit this offer? Once submitted, the client will be notified.")) {
                    e.preventDefault();
                }
            });
        });
    </script>
}
