@model HandyGo.web.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Login - HandyGo</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-color: #0d6efd;
            --dark-color: #1a202c;
        }

        
        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
            width: 100%;
            overflow: hidden; 
            overscroll-behavior: none;
            touch-action: none; 
        }

        body {
            background: url('https://images.unsplash.com/photo-1505798577917-a65157d3320a?q=80&w=2070&auto=format&fit=crop') no-repeat center center fixed;
            background-size: cover;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            position: relative;
        }

            body::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.5);
                z-index: 1;
            }

        .login-container {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 420px;
            padding: 15px;
            
            max-height: 100vh;
            overflow-y: auto;
            touch-action: pan-y;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 28px;
            padding: 35px 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            text-align: center;
        }

        .brand-icon {
            width: 60px;
            height: 60px;
            background: var(--primary-color);
            color: white;
            border-radius: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            margin-bottom: 20px;
        }

        .login-header h2 {
            font-weight: 800;
            color: var(--dark-color);
            margin-bottom: 5px;
            font-size: 1.75rem;
        }

        .login-header p {
            font-size: 0.9rem;
            color: #718096;
            margin-bottom: 25px;
        }

        
        .text-danger {
            font-size: 0.8rem;
            display: block;
            text-align: left;
            margin-top: 4px;
            font-weight: 500;
        }

        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
            color: #dc3545;
            margin-bottom: 15px;
            font-size: 0.85rem;
            text-align: center;
        }

        .form-floating > .form-control {
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            height: 55px;
        }

        .btn-login {
            background: var(--dark-color);
            color: white;
            border: none;
            height: 52px;
            border-radius: 12px;
            font-weight: 700;
            margin-top: 10px;
            transition: 0.3s;
        }

            .btn-login:hover {
                background: #000;
                transform: translateY(-2px);
            }

        .divider {
            display: flex;
            align-items: center;
            margin: 20px 0;
            color: #cbd5e0;
            font-size: 0.7rem;
            text-transform: uppercase;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                border-bottom: 1px solid #edf2f7;
            }

            .divider span {
                padding: 0 10px;
            }

        .signup-link {
            color: var(--primary-color);
            font-weight: 800;
            text-decoration: none;
        }

        .alert-custom {
            font-size: 0.85rem;
            padding: 10px;
            border-radius: 12px;
            margin-bottom: 20px;
            border: none;
        }

        .btn-google {
            border: 1px solid #e2e8f0;
            height: 52px;
            border-radius: 12px;
            font-weight: 700;
            color: #4a5568;
            background: white;
            transition: 0.3s;
        }

            .btn-google:hover {
                background: #f8f9fa;
                color: #1a202c;
                transform: translateY(-2px);
                box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-card">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show alert-custom shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="padding: 0.8rem;"></button>
                </div>
            }
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-info alert-dismissible fade show alert-custom shadow-sm" role="alert">
                    <i class="bi bi-info-circle-fill me-2"></i>@TempData["Message"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="padding: 0.8rem;"></button>
                </div>
            }
            
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show alert-custom shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="padding: 0.8rem;"></button>
                </div>
            }

            <div class="brand-icon">
                <i class="bi bi-tools"></i>
            </div>

            <div class="login-header">
                <h2>Welcome Back</h2>
                <p>Enter your details to access HandyGo</p>
            </div>

            <form asp-action="Login" method="post">
                
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold text-center"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control" id="emailInput" placeholder="name@example.com">
                    <label for="emailInput">Email address</label>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Password" type="password" class="form-control" id="passInput" placeholder="Password">
                    <label for="passInput">Password</label>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4 px-1">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="rememberMeCheckbox">
                        <label class="form-check-label small text-muted" for="rememberMeCheckbox">Remember me</label>
                    </div>
                    
                    <a asp-action="ForgotPassword" asp-controller="Account" class="small text-decoration-none fw-semibold">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-login w-100 shadow-sm">
                    Sign In <i class="bi bi-arrow-right-short ms-1"></i>
                </button>

                <div class="divider">
                    <span>Or connect with</span>
                </div>

                
                <a asp-action="ExternalLogin" asp-controller="Account" class="btn w-100 d-flex align-items-center justify-content-center gap-2 mb-4 btn-google">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="22px" height="22px">
                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                        <path fill="none" d="M0 0h48v48H0z" />
                    </svg>
                    Continue with Google
                </a>

                <div class="text-center">
                    <p class="small text-muted mb-0">
                        New to HandyGo?
                        <a asp-action="Register" class="signup-link ms-1">Create Account</a>
                    </p>
                </div>
            </form>
        </div>
    </div>

    
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>
