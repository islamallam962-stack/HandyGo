@using HandyGo.web.ViewModels
@model dynamic

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 25px;
    }

    .address-group {
    position: relative;
    }

    .map-trigger-btn {
    position: absolute;
    right: 5px;
    top: 50%;
    transform: translateY(-50%);
    border: none;
    background: none;
    color: #0d6efd;
    padding: 5px 10px;
    z-index: 5;
    }

    .nav-pills .nav-link {
    color: #555;
    transition: 0.3s;
    }

    .nav-pills .nav-link.active {
    background-color: #0d6efd !important;
    color: white !important;
    }
</style>

<div class="container py-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 rounded-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4 rounded-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold text-dark mb-1"><i class="bi bi-tools me-2 text-primary"></i>Available Technicians</h2>
            <div class="text-muted small">Select a technician and pin your location on the map</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button onclick="refreshWithGPSLocation()" class="btn btn-outline-primary rounded-pill px-4 shadow-sm fw-bold">
                <i class="bi bi-crosshair me-2"></i> Locate Me (GPS)
            </button>
            <a asp-controller="Offers" asp-action="LiveMap" class="btn btn-dark rounded-pill px-4 shadow-sm fw-bold">
                <i class="bi bi-map me-2"></i> View Technicians on Map
            </a>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm flex-wrap gap-3">
        <div class="text-muted small">
            <i class="bi bi-shield-check text-success fs-5 me-1"></i> Showing active technicians (within 24h) within a <strong>30 km</strong> radius only.
        </div>
        
        <div class="btn-group shadow-sm" role="group">
            <a href="/Offers/Index?sort=distance&lat=@ViewBag.CurrentUserLat&lng=@ViewBag.CurrentUserLng"
                   class="btn @(ViewBag.CurrentSort == "distance" || string.IsNullOrEmpty(ViewBag.CurrentSort) ? "btn-primary" : "btn-light border") fw-bold"
                   style="border-top-left-radius: 50rem; border-bottom-left-radius: 50rem;">
                <i class="bi bi-geo-alt me-1"></i> Closest to you
            </a>
            <a href="/Offers/Index?sort=rating&lat=@ViewBag.CurrentUserLat&lng=@ViewBag.CurrentUserLng"
                   class="btn @(ViewBag.CurrentSort == "rating" ? "btn-primary" : "btn-light border") fw-bold"
                   style="border-top-right-radius: 50rem; border-bottom-right-radius: 50rem;">
                <i class="bi bi-star-fill me-1 text-warning"></i> Top Rated
            </a>
        </div>
    </div>

    <div class="alert alert-info py-2 px-3 mb-4 small rounded-pill d-inline-block shadow-sm">
        <i class="bi bi-info-circle me-1"></i> Click on the map to set your address automatically
    </div>

    <ul class="nav nav-pills mb-4 shadow-sm p-2 bg-white rounded-pill justify-content-center" id="techTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active rounded-pill px-4 fw-bold" data-bs-toggle="pill" data-bs-target="#plumbers-section">
                <i class="bi bi-droplet-fill me-1"></i> Plumbers
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-pill px-4 fw-bold" data-bs-toggle="pill" data-bs-target="#electricians-section">
                <i class="bi bi-lightning-charge-fill me-1"></i> Electricians
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-pill px-4 fw-bold" data-bs-toggle="pill" data-bs-target="#ac-section">
                <i class="bi bi-snow me-1"></i> AC Technicians
            </button>
        </li>
    </ul>

    <div class="tab-content pt-2">
        <div class="tab-pane fade show active" id="plumbers-section">
            <div class="tech-grid">
                @if (ViewBag.Plumbers != null && ((List<TechnicianOffersViewModel>)ViewBag.Plumbers).Any())
                {
                    @foreach (var item in (List<TechnicianOffersViewModel>)ViewBag.Plumbers)
                    {
                        @await Html.PartialAsync("_TechnicianList", item)
                    }
                }
                else
                {
                    <div class="col-12 text-center text-muted py-5 w-100">
                        <i class="bi bi-emoji-frown fs-1 d-block mb-2"></i> No plumbers available in your area at the moment.
                    </div>
                }
            </div>
        </div>

        <div class="tab-pane fade" id="electricians-section">
            <div class="tech-grid">
                @if (ViewBag.Electricians != null && ((List<TechnicianOffersViewModel>)ViewBag.Electricians).Any())
                {
                    @foreach (var item in (List<TechnicianOffersViewModel>)ViewBag.Electricians)
                    {
                        @await Html.PartialAsync("_TechnicianList", item)
                    }
                }
                else
                {
                    <div class="col-12 text-center text-muted py-5 w-100">
                        <i class="bi bi-emoji-frown fs-1 d-block mb-2"></i> No electricians available in your area at the moment.
                    </div>
                }
            </div>
        </div>

        <div class="tab-pane fade" id="ac-section">
            <div class="tech-grid">
                @if (ViewBag.AC != null && ((List<TechnicianOffersViewModel>)ViewBag.AC).Any())
                {
                    @foreach (var item in (List<TechnicianOffersViewModel>)ViewBag.AC)
                    {
                        @await Html.PartialAsync("_TechnicianList", item)
                    }
                }
                else
                {
                    <div class="col-12 text-center text-muted py-5 w-100">
                        <i class="bi bi-emoji-frown fs-1 d-block mb-2"></i> No AC technicians available in your area at the moment.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mapModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-map me-2"></i>Select Service Location</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div id="map" style="height: 400px; width: 100%;"></div>
                <div class="p-3 bg-light d-flex gap-2 align-items-center">
                    <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold" onclick="getCurrentLocation()">
                        <i class="bi bi-crosshair me-1"></i> My Location
                    </button>
                    <span id="addressLoader" class="spinner-border spinner-border-sm text-primary d-none"></span>
                    <small id="currentSelectedAddress" class="text-secondary fw-bold ms-2">Click map to pick address...</small>
                </div>
            </div>
            <div class="modal-footer bg-white border-0">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold" id="confirmLocationBtn">Confirm Location</button>
            </div>
        </div>
    </div>
</div>

<script>
    let map, marker;
    let currentInputId = '';
    let currentLatInputId = '';
    let currentLngInputId = '';
    let selectedLat = null;
    let selectedLng = null;

    document.getElementById('mapModal').addEventListener('shown.bs.modal', function () {
    if (!map) {
    let startLat = @(ViewBag.CurrentUserLat != 0 ? ViewBag.CurrentUserLat : 30.0444);
    let startLng = @(ViewBag.CurrentUserLng != 0 ? ViewBag.CurrentUserLng : 31.2357);

    map = L.map('map').setView([startLat, startLng], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

    marker = L.marker([startLat, startLng], { draggable: true }).addTo(map);

    map.on('click', function(e) {
    updateMarker(e.latlng.lat, e.latlng.lng);
    });

    marker.on('dragend', function(e) {
    let position = marker.getLatLng();
    updateMarker(position.lat, position.lng);
    });
    }
    map.invalidateSize();
    });

    function openMap(inputId, latId, lngId) {
    currentInputId = inputId;
    currentLatInputId = latId;
    currentLngInputId = lngId;
    let modal = new bootstrap.Modal(document.getElementById('mapModal'));
    modal.show();
    }

    function updateMarker(lat, lng) {
    selectedLat = lat;
    selectedLng = lng;

    marker.setLatLng([lat, lng]);
    map.panTo([lat, lng]);

    document.getElementById('addressLoader').classList.remove('d-none');
    fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`)
    .then(response => response.json())
    .then(data => {
    let addr = data.display_name;
    document.getElementById('currentSelectedAddress').innerText = addr;
    document.getElementById('addressLoader').classList.add('d-none');
    });
    }

    function getCurrentLocation() {
    if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(position => {
    updateMarker(position.coords.latitude, position.coords.longitude);
    }, () => {
    alert("Please enable location services in your device/browser.");
    });
    } else {
    alert("Your browser does not support geolocation.");
    }
    }

    function refreshWithGPSLocation() {
    if (navigator.geolocation) {
    let currentSort = '@(string.IsNullOrEmpty(ViewBag.CurrentSort) ? "distance" : ViewBag.CurrentSort)';
    navigator.geolocation.getCurrentPosition(function (position) {
    window.location.href = `/Offers/Index?sort=${currentSort}&lat=${position.coords.latitude}&lng=${position.coords.longitude}`;
    }, function () {
    alert("Please allow the browser to access your location to see nearby technicians.");
    });
    } else {
    alert("Your browser does not support geolocation.");
    }
    }

    document.getElementById('confirmLocationBtn').onclick = function() {
    let fullAddress = document.getElementById('currentSelectedAddress').innerText;

    if (currentInputId && document.getElementById(currentInputId)) {
    document.getElementById(currentInputId).value = fullAddress;
    }
    if (currentLatInputId && document.getElementById(currentLatInputId)) {
    document.getElementById(currentLatInputId).value = selectedLat;
    }
    if (currentLngInputId && document.getElementById(currentLngInputId)) {
    document.getElementById(currentLngInputId).value = selectedLng;
    }

    bootstrap.Modal.getInstance(document.getElementById('mapModal')).hide();
    };
</script>
