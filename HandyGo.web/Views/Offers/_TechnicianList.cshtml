@model HandyGo.web.Models.TechnicianOffersViewModel
<div class="tech-card shadow-sm p-3 h-100 d-flex flex-column" style="position: relative; border: 1px solid #edf2f7; border-radius: 16px; background: #fff;">

    
    @if (Model.Technician.IsTopRated)
    {
        <span class="badge-staff text-uppercase" style="position: absolute; top: -10px; left: 15px; background: #198754; color: #fff; padding: 4px 12px; border-radius: 8px; font-size: 0.7rem; font-weight: 800; z-index: 10;">
            <i class="bi bi-patch-check-fill me-1"></i>Staff Pick
        </span>
    }

    
    @if (Model.AverageRating >= 4.2)
    {
        <span class="badge-top text-uppercase" style="position: absolute; top: -10px; right: 15px; background: #ffc107; color: #000; padding: 4px 12px; border-radius: 8px; font-size: 0.7rem; font-weight: 800; z-index: 10;">
            <i class="bi bi-trophy-fill me-1"></i>Top Rated
        </span>
    }

    
    <div class="img-wrapper mb-3" style="height: 180px; overflow: hidden; border-radius: 12px;">
        <a asp-controller="Profile" asp-action="Details" asp-route-id="@Model.Technician.Id">
            <img src="@(Model.Technician.ImagePath ?? "/images/default.png")" class="w-100 h-100" style="object-fit: cover;" alt="@Model.Technician.Name" />
        </a>
    </div>

    
    <a asp-controller="Profile" asp-action="Details" asp-route-id="@Model.Technician.Id" class="text-decoration-none text-dark">
        <h5 class="fw-bold mb-1">@Model.Technician.Name</h5>
    </a>

    
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center">
            <div class="text-warning me-2">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="bi @(i <= Math.Round(Model.AverageRating) ? "bi-star-fill" : "bi-star")"></i>
                }
            </div>
            <span class="small fw-bold text-muted">(@Model.AverageRating.ToString("0.0"))</span>
        </div>
        
        
        @if (Model.Distance < 9999)
        {
            <span class="small fw-bold text-primary bg-primary-subtle px-2 py-1 rounded-pill" style="font-size: 0.75rem;">
                <i class="bi bi-geo-alt-fill me-1"></i> @Model.Distance km
            </span>
        }
    </div>

    
    <div class="mb-3" style="height: 60px; overflow: hidden;">
        @if (!string.IsNullOrEmpty(Model.Technician.Skills))
        {
            var skills = Model.Technician.Skills.Split(',', StringSplitOptions.RemoveEmptyEntries);
            foreach (var skill in skills.Take(4)) 
            {
                <span class="d-inline-block bg-light text-primary px-2 py-1 rounded-pill small fw-semibold me-1 mb-1 border border-primary-subtle" style="font-size: 0.75rem;">
                    @skill.Trim()
                </span>
            }
            if (skills.Length > 4)
            {
                <span class="d-inline-block bg-light text-secondary px-2 py-1 rounded-pill small fw-bold mb-1 border" style="font-size: 0.75rem;">
                    +@(skills.Length - 4)
                </span>
            }
        }
        else
        {
            <p class="text-muted small fst-italic mb-0">No skills listed yet.</p>
        }
    </div>

    
    <div class="bg-light rounded p-2 mb-3 flex-grow-1 border">
        <small class="d-block fw-bold text-primary mb-1" style="font-size: 0.7rem;"><i class="bi bi-chat-quote-fill me-1"></i>LATEST REVIEW:</small>
        @if (Model.Reviews != null && Model.Reviews.Any())
        {
            var rev = Model.Reviews.OrderByDescending(r => r.CreatedAt).First();
            <small class="text-dark fst-italic d-block" style="font-size: 0.8rem; line-height: 1.3;">
                "@(rev.Comment?.Length > 50 ? rev.Comment.Substring(0, 47) + "..." : rev.Comment)"
            </small>
        }
        else
        {
            <small class="text-muted" style="font-size: 0.8rem;">No feedback yet</small>
        }
    </div>

    
    <form asp-controller="Offers" asp-action="RequestService" method="post" class="mt-auto">

        <input type="hidden" name="technicianId" value="@Model.Technician.Id" />

        <input type="hidden" id="lat-@Model.Technician.Id" name="Latitude" />
        <input type="hidden" id="lng-@Model.Technician.Id" name="Longitude" />

        <div class="input-group input-group-sm mb-2 position-relative">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-geo-alt text-danger"></i></span>

            <input type="text"
                   id="address-@Model.Technician.Id"
                   name="Address"
                   class="form-control border-start-0 ps-0 pe-5"
                   placeholder="Your Address"
                   required readonly />

            <button type="button"
                    onclick="openMap('address-@Model.Technician.Id', 'lat-@Model.Technician.Id', 'lng-@Model.Technician.Id')"
                    class="btn position-absolute end-0 top-0 h-100 border-0 text-primary"
                    style="z-index: 5; background: transparent;" title="Pick Location on Map">
                <i class="bi bi-map-fill fs-5"></i>
            </button>
        </div>

        <button type="submit" class="btn btn-primary btn-sm w-100 fw-bold rounded-pill py-2 shadow-sm mt-1 transition-all">
            Request Service <i class="bi bi-arrow-right-short ms-1"></i>
        </button>
    </form>
</div>
