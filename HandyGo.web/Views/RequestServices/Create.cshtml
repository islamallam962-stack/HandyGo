@{
    ViewData["Title"] = "Request Service";
    var savedAddr = ViewBag.CurrentUserAddress as string ?? "";
    var savedLat = ViewBag.CurrentUserLat?.ToString() ?? "";
    var savedLng = ViewBag.CurrentUserLng?.ToString() ?? "";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f0f2f5;
    }

    .request-container {
        max-width: 800px;
        margin: 40px auto;
    }

    .glass-card {
        background: #ffffff;
        border-radius: 25px;
        border: none;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .header-section {
        background: linear-gradient(45deg, #0984e3, #00cec9);
        padding: 40px;
        color: white;
        text-align: center;
    }

    .form-body {
        padding: 40px;
    }

    .method-card {
        border: 2px solid #f1f2f6;
        border-radius: 15px;
        padding: 20px;
        transition: 0.3s;
        cursor: pointer;
        position: relative;
    }

        .method-card:hover {
            border-color: #0984e3;
            background: #f8fbff;
        }

    .form-check-input:checked + .method-card {
        border-color: #0984e3;
        background: #f0f7ff;
    }

    .location-trigger {
        background: #f8f9fa;
        border: 2px dashed #cbd5e0;
        border-radius: 15px;
        padding: 15px;
        text-align: center;
        cursor: pointer;
        transition: 0.3s;
    }

        .location-trigger:hover {
            background: #edf2f7;
            border-color: #0984e3;
        }

    .map-container {
        height: 350px;
        border-radius: 15px;
    }

    .btn-submit {
        background: linear-gradient(45deg, #0984e3, #00cec9);
        border: none;
        border-radius: 15px;
        padding: 15px;
        font-weight: 700;
        font-size: 1.1rem;
        transition: 0.3s;
    }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(9,132,227,0.3);
        }
</style>

<div class="container request-container">
    <div class="glass-card">
        <div class="header-section">
            <h2 class="fw-bold mb-2"><i class="bi bi-megaphone me-2"></i>Post a Request</h2>
            <p class="opacity-75">Tell us what you need and we'll handle the rest</p>
        </div>

        <div class="form-body">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-pill px-4 shadow-sm mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                </div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success rounded-pill px-4 shadow-sm mb-4">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                </div>
            }

            <form asp-action="Create" method="post" id="mainRequestForm">
                <div class="mb-4">
                    <label class="form-label fw-bold text-dark"><i class="bi bi-tag-fill me-2"></i>Service Category</label>
                    <select name="ServiceType" class="form-select form-select-lg rounded-pill" required>
                        <option value="">Choose the type of expert needed...</option>
                        <option value="Plumber">Plumbing</option>
                        <option value="Electrician">Electrical</option>
                        <option value="AC">Air Conditioning</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-dark"><i class="bi bi-geo-alt-fill me-2"></i>Service Location</label>
                    <input type="hidden" name="Latitude" id="mainLat" value="@savedLat" />
                    <input type="hidden" name="Longitude" id="mainLng" value="@savedLng" />
                    <input type="hidden" name="Address" id="mainAddr" value="@savedAddr" required />

                    <div class="location-trigger" onclick="openMapModal()">
                        <div id="addrDisplay" class="text-primary fw-bold">
                            @(string.IsNullOrEmpty(savedAddr) ? "Click to pinpoint your location on the map" : savedAddr)
                        </div>
                    </div>
                </div>

                <div class="mb-5">
                    <label class="form-label fw-bold text-dark mb-3"><i class="bi bi-lightning-charge-fill me-2"></i>Assignment Method</label>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="w-100">
                                <input type="radio" name="AssignmentMethod" value="Smart" class="form-check-input d-none" checked>
                                <div class="method-card text-center">
                                    <i class="bi bi-cpu fs-2 text-primary"></i>
                                    <h6 class="fw-bold mt-2">Smart Match</h6>
                                    <small class="text-muted">Directly assign to the best available tech</small>
                                </div>
                            </label>
                        </div>
                        <div class="col-md-6">
                            <label class="w-100">
                                <input type="radio" name="AssignmentMethod" value="Public" class="form-check-input d-none">
                                <div class="method-card text-center">
                                    <i class="bi bi-people fs-2 text-success"></i>
                                    <h6 class="fw-bold mt-2">Public Request</h6>
                                    <small class="text-muted">Broadcast to all and wait for bids</small>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-3">
                    <button type="submit" class="btn btn-primary btn-submit text-white shadow">
                        Send My Request
                    </button>
                    <a asp-action="Index" asp-controller="Profile" onclick="localStorage.setItem('activeTab', 'profileTab');" class="btn btn-link text-muted text-decoration-none">Cancel and go back</a>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="mapModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 25px;">
            <div class="modal-header border-0 pb-0 pt-4 px-4">
                <h5 class="fw-bold m-0"><i class="bi bi-map me-2"></i>Pinpoint Your Location</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4">
                <button type="button" class="btn btn-outline-primary btn-sm mb-3 w-100 fw-bold py-2" onclick="getCurrentGPS()">
                    <i class="bi bi-crosshair"></i> Use My Current Location (GPS)
                </button>
                <div id="map" class="map-container"></div>
                <div id="modalAddrDisplay" class="mt-3 p-3 bg-light rounded text-primary fw-bold small border-start border-4 border-primary">
                    Fetching address...
                </div>
            </div>
            <div class="modal-footer border-0 p-4">
                <button type="button" class="btn btn-primary w-100 py-3 fw-bold shadow" onclick="saveLocation()">Confirm This Location</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        let map, marker, tempLat, tempLng, tempAddr;

        function getCurrentGPS() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(p => {
                    const lat = p.coords.latitude;
                    const lng = p.coords.longitude;
                    map.setView([lat, lng], 17);
                    marker.setLatLng([lat, lng]);
                    reverseGeocode(lat, lng);
                }, () => {
                    alert("Please allow location access to use GPS.");
                });
            }
        }

        function openMapModal() {
            $('#mapModal').modal('show');
            const currentLat = parseFloat($("#mainLat").val()) || 30.0444;
            const currentLng = parseFloat($("#mainLng").val()) || 31.2357;

            setTimeout(() => {
                if (!map) {
                    map = L.map('map').setView([currentLat, currentLng], 15);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
                    marker = L.marker([currentLat, currentLng], {draggable: true}).addTo(map);
                    marker.on('dragend', e => reverseGeocode(e.target.getLatLng().lat, e.target.getLatLng().lng));
                    map.on('click', e => { marker.setLatLng(e.latlng); reverseGeocode(e.latlng.lat, e.latlng.lng); });
                }
                reverseGeocode(currentLat, currentLng);
            }, 400);
        }

        function reverseGeocode(lat, lng) {
            document.getElementById('modalAddrDisplay').innerText = "? Loading address...";
            fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`)
                .then(r => r.json())
                .then(data => {
                    tempLat = lat; tempLng = lng; tempAddr = data.display_name;
                    document.getElementById('modalAddrDisplay').innerText = "?? " + tempAddr;
                });
        }

        function saveLocation() {
            if(!tempAddr) {
                alert("Please select a valid location on the map.");
                return;
            }
            $("#mainLat").val(tempLat);
            $("#mainLng").val(tempLng);
            $("#mainAddr").val(tempAddr);
            $("#addrDisplay").text(tempAddr);
            $('#mapModal').modal('hide');
        }

        $("#mainRequestForm").on("submit", function(e) {
            if ($("#mainAddr").val() === "" || $("#mainLat").val() === "" || $("#mainLng").val() === "") {
                e.preventDefault();
                alert("Please pin your exact location on the map first.");
            }
        });
    </script>
}
