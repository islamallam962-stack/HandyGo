                                    </form>
                                }
                                else
                                {
                                    <a class="text-decoration-none fw-bold text-dark px-2" asp-controller="Account" asp-action="Login">Sign In</a>
                                    <a class="btn btn-primary btn-sm px-4 rounded-pill shadow-sm" asp-controller="Account" asp-action="Register">Sign Up</a>
                                }
                            </div>
                        </div>

                    </div>
                </nav>

                <audio id="notificationSound" src="/sounds/notification.mp3" preload="auto"></audio>
            </header>

            <!-- ??? PWA Floating Install Banner ????????????????????????????? -->
            <div id="pwaInstallBanner" role="complementary" aria-label="Install App">
                <div class="pwa-icon">
                    <i class="bi bi-phone-vibrate text-warning"></i>
                </div>
                <div class="pwa-text">
                    <strong>ĘäŇíá ĘŘČíŢ HandyGo</strong>
                    <span>ĘĚŃČÉ ĂÓŃÚ ćĂÝÖá Úáě ĚĺÇŇß</span>
                </div>
                <button class="pwa-install-btn" id="installPwaBtn">ĘäŇíá</button>
                <button class="pwa-close-btn" id="pwaCloseBanner" aria-label="ĹŰáÇŢ"><i class="bi bi-x-lg"></i></button>
            </div>

            <main role="main" class="container my-4">
                @RenderBody()
            </main>

            <footer class="mt-auto py-3 border-top bg-white">
                <div class="container text-center">
                    <p class="text-muted small mb-0">&copy; 2026 HandyGo Platform - Professional Home Services</p>
                </div>
            </footer>

            <script src="~/lib/jquery/dist/jquery.min.js"></script>
            <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
            <script src="~/js/site.js" asp-append-version="true"></script>
            <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

            <script>
                function updateAllNotifications() {
                const isLoggedIn = "@(userId != null)";
                const userRole = "@userRole";

                if (isLoggedIn === "True") {
                fetch('/Notification/GetMyNotifications')
                .then(res => res.json())
                .then(data => {
                const countBadge = document.getElementById('notifCount');
                const openReqBadge = document.getElementById('openRequestsBadge');

                if (data.count > 0) {
                countBadge.innerText = data.count;
                countBadge.style.display = 'block';
                } else {
                countBadge.style.display = 'none';
                }

                if (openReqBadge) {
                const offerCount = data.items.filter(n => !n.isRead && n.link && n.link.includes("OffersPrice")).length;
                if (offerCount > 0) {
                openReqBadge.innerText = offerCount;
                openReqBadge.style.display = 'block';
                } else {
                openReqBadge.style.display = 'none';
                }
                }

                const itemsDiv = document.getElementById('notifItems');
                if (data.items.length === 0) {
                itemsDiv.innerHTML = '<li class="p-4 text-center text-muted">No new notifications</li>';
                } else {
                itemsDiv.innerHTML = data.items.map(n => `
                <li class="notif-item ${n.isRead ? '' : 'notif-unread'}">
                <a class="dropdown-item py-3" href="/Notification/Open?id=${n.id}">
                <div class="d-flex align-items-start">
                <div class="flex-grow-1">
                <div class="small text-dark mb-1" style="white-space:normal;">${n.message}</div>
                <div class="text-muted" style="font-size:0.75rem;"><i class="bi bi-clock me-1"></i>${n.time}</div>
                </div>
                ${!n.isRead ? '<span class="p-1 bg-primary border border-light rounded-circle ms-2"></span>' : ''}
                </div>
                </a>
                </li>
                `).join('');
                }
                });

                fetch('/Chat/GetTotalUnseenMessages')
                .then(res => res.json())
                .then(data => {
                const badge = document.getElementById('globalChatBadge');
                if (badge) {
                badge.innerText = data;
                badge.style.display = data > 0 ? 'block' : 'none';
                }
                });

                if (userRole === "Technician") {
                fetch('/TechnicianRequests/GetPendingRequestsCount')
                .then(res => res.json())
                .then(data => {
                const badge = document.getElementById('techRequestBadge');
                if (badge) {
                badge.innerText = data;
                badge.style.display = data > 0 ? 'block' : 'none';
                }
                });
                }
                }
                }

                function clearNotifications() {
                fetch('/Notification/ClearAll', { method: 'POST' }).then(() => updateAllNotifications());
                }

                $('#notifDropdown').on('click', function () {
                fetch('/Notification/MarkAsRead', { method: 'POST' }).then(() => {
                document.getElementById('notifCount').style.display = 'none';
                });
                });

                const connection = new signalR.HubConnectionBuilder().withUrl("/notificationHub").build();

                connection.on("ReceiveNotification", function () {
                const sound = document.getElementById("notificationSound");
                if (sound) sound.play().catch(e => console.log("Sound muted by browser policy"));
                updateAllNotifications();
                });

                connection.start().catch(err => console.error(err.toString()));

                setInterval(updateAllNotifications, 20000);
                updateAllNotifications();
            </script>

            <script>
                if ('serviceWorker' in navigator) {
                window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                .then(registration => {
                console.log('PWA ServiceWorker registered successfully!');
                })
                .catch(err => {
                console.log('PWA ServiceWorker registration failed: ', err);
                });
                });
                }
            </script>

            <script>
                let deferredPrompt;
                const installContainer = document.getElementById('pwaInstallBanner');
                const installBtn = document.getElementById('installPwaBtn');
                const closeBannerBtn = document.getElementById('pwaCloseBanner');

                window.addEventListener('beforeinstallprompt', (e) => {

                e.preventDefault();

                deferredPrompt = e;

                setTimeout(() => {
                if (installContainer) installContainer.classList.add('show');
                }, 2000);
                });

                if (installBtn) {
                installBtn.addEventListener('click', async () => {
                if (deferredPrompt) {

                deferredPrompt.prompt();

                const { outcome } = await deferredPrompt.userChoice;

                deferredPrompt = null;
                if (installContainer) installContainer.classList.remove('show');
                }
                });
                }

                if (closeBannerBtn) {
                closeBannerBtn.addEventListener('click', () => {
                if (installContainer) installContainer.classList.remove('show');
                });
                }

                window.addEventListener('appinstalled', () => {
                console.log('Ęă ĘËČíĘ ĘŘČíŢ HandyGo ČäĚÇÍ!');
                if (installContainer) installContainer.classList.remove('show');
                });
            </script>

            @await RenderSectionAsync("Scripts", required: false)
        </body>
    </html>

