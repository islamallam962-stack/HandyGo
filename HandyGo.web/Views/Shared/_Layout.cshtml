                                        </li>
                                        <div id="notifItems" style="max-height:300px;overflow-y:auto;">
                                            <li class="p-4 text-center text-muted small">Loading...</li>
                                        </div>
                                    </ul>
                                </div>

                                <!-- VIP Star -->
                                <a class="nav-link icon-btn text-warning" asp-controller="Subscription" asp-action="Index" title="ČÇŢÇĘ VIP">
