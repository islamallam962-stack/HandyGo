                                <li class="nav-item"><a class="nav-link" href="/Home#services">Services</a></li>
                                <li class="nav-item"><a class="nav-link" href="/Home#about">About</a></li>

                                @if (userId != null)
                                {
                                    <li class="nav-item dropdown">
