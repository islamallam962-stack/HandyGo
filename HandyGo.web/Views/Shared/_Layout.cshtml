@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@inject HandyGo.web.Data.AppDbContext _context

@{
    var userId = Context.Session.GetInt32("UserId");
    var userRole = Context.Session.GetString("UserRole");
    var userName = Context.Session.GetString("UserName");

    int newOffersCount = 0;
    decimal currentWalletBalance = 0;

    if (userId != null)
    {
        if (userRole == "Client")
        {
            newOffersCount = _context.Notifications
                .Count(n => n.UserId == userId && !n.IsRead && n.Link.Contains("OffersPrice"));
        }

        var currentUser = _context.Users.Find(userId.Value);
        if (currentUser != null)
        {
            currentWalletBalance = currentUser.WalletBalance;
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HandyGo</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link rel="manifest" href="~/manifest.json">
        <meta name="theme-color" content="#007bff">
        <link rel="apple-touch-icon" href="~/images/logo.png">

            <style>
                    :root {
                        --primary-color: #0d6efd;
                    }

                    body {
                        font-family: 'Inter', sans-serif;
                        background-color: #f8f9fa;
                        overflow-x: hidden;
                    }

                    
                    .navbar {
                        backdrop-filter: blur(10px);
                        background-color: rgba(255, 255, 255, 0.97) !important;
                        padding: 0.55rem 0;
                        border-bottom: 1px solid rgba(0,0,0,0.07) !important;
                    }

                    .navbar-brand {
                        font-size: 1.35rem;
                        letter-spacing: -0.3px;
                    }

                    
                    .nav-link {
                        font-weight: 500;
                        color: #444 !important;
                        font-size: 0.92rem;
                        padding: 0.45rem 0.75rem !important;
                        border-radius: 6px;
                        transition: background 0.15s, color 0.15s;
                    }

                        .nav-link:hover {
                            background-color: #f0f4ff;
                            color: var(--primary-color) !important;
                        }

                    
                    .navbar .icon-btn {
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        width: 38px;
                        height: 38px;
                        border-radius: 50%;
                        color: #555 !important;
                        transition: background 0.15s, color 0.15s;
                        position: relative;
                    }

                        .navbar .icon-btn:hover {
                            background-color: #f0f4ff;
                            color: var(--primary-color) !important;
                        }

                        .navbar .icon-btn .bi {
                            font-size: 1.15rem;
                            line-height: 1;
                        }

                    
                    .badge-modern {
                        font-size: 0.58rem;
                        min-width: 16px;
                        height: 16px;
                        line-height: 1;
                        padding: 2px 4px;
                        border: 2px solid #fff;
                        top: 2px !important;
                        right: 2px !important;
                    }

                    
                    .notification-dropdown {
                        width: 320px;
                        max-width: 92vw;
                        border: none;
                        border-radius: 14px;
                        box-shadow: 0 12px 36px rgba(0,0,0,0.11);
                        overflow: hidden;
                    }

                    
                    .user-badge {
                        background: #f0f4ff;
                        padding: 5px 14px;
                        border-radius: 50px;
                        font-size: 0.82rem;
                        font-weight: 600;
                        color: var(--primary-color);
                        white-space: nowrap;
                        border: 1px solid #d9e5ff;
                    }

                    
                    .nav-icon-group {
                        display: flex;
                        align-items: center;
                        gap: 2px;
                    }

                    
                    .navbar .dropdown-menu {
                        border: none;
                        border-radius: 10px;
                        box-shadow: 0 8px 24px rgba(0,0,0,0.09);
                        padding: 6px;
                        margin-top: 8px !important;
                    }

                    .navbar .dropdown-item {
                        border-radius: 6px;
                        font-size: 0.88rem;
                        padding: 8px 14px;
                        transition: background 0.12s;
                    }

                        .navbar .dropdown-item:hover {
                            background-color: #f0f4ff;
                        }

                    
                    .wallet-btn {
                        font-size: 0.82rem;
                        padding: 5px 14px;
                        border-radius: 50px;
                        font-weight: 600;
                        white-space: nowrap;
                    }

                    
                    @@media (max-width: 991.98px) {
                        .navbar-collapse {
                            background: white;
                            padding: 1rem 1.2rem;
                            border-radius: 10px;
                            margin-top: 10px;
                            box-shadow: 0 6px 20px rgba(0,0,0,0.09);
                        }

                        .navbar-nav {
                            margin-bottom: 0.75rem;
                        }

                        .user-controls {
                            flex-direction: column;
                            align-items: flex-start !important;
                            width: 100%;
                            gap: 0.75rem !important;
                            padding-top: 0.5rem;
                            border-top: 1px solid #f0f0f0;
                        }

                        .user-badge {
                            display: inline-block !important;
                        }

                        .wallet-btn {
                            width: 100%;
                            text-align: center;
                        }
                    }

                    @@media (max-width: 576px) {
                        .navbar-brand {
                            font-size: 1.1rem;
                        }

                        .notification-dropdown {
                            right: -55px;
                            position: absolute;
                        }
                    }

                    
                    #pwaInstallBanner {
                        position: fixed;
                        bottom: 24px;
                        left: 50%;
                        transform: translateX(-50%) translateY(120px);
                        z-index: 9999;
                        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
                        color: white;
                        border-radius: 18px;
                        padding: 14px 20px;
                        display: flex;
                        align-items: center;
                        gap: 14px;
                        box-shadow: 0 8px 32px rgba(0,0,0,0.28), 0 2px 8px rgba(13,110,253,0.18);
                        min-width: 300px;
                        max-width: 92vw;
                        transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
                        opacity: 0;
                        pointer-events: none;
                    }

                        #pwaInstallBanner.show {
                            transform: translateX(-50%) translateY(0);
                            opacity: 1;
                            pointer-events: auto;
                        }

                        #pwaInstallBanner .pwa-icon {
                            width: 44px;
                            height: 44px;
                            background: rgba(255,255,255,0.1);
                            border-radius: 12px;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            flex-shrink: 0;
                            font-size: 1.4rem;
                        }

                        #pwaInstallBanner .pwa-text {
                            flex: 1;
                            min-width: 0;
                        }

                            #pwaInstallBanner .pwa-text strong {
                                display: block;
                                font-size: 0.88rem;
                                font-weight: 700;
                                margin-bottom: 2px;
                            }

                            #pwaInstallBanner .pwa-text span {
                                font-size: 0.75rem;
                                color: rgba(255,255,255,0.62);
                                display: block;
                                white-space: nowrap;
                                overflow: hidden;
                                text-overflow: ellipsis;
                            }

                        #pwaInstallBanner .pwa-install-btn {
                            background: #0d6efd;
                            color: white;
                            border: none;
                            border-radius: 10px;
                            padding: 8px 16px;
                            font-size: 0.82rem;
                            font-weight: 700;
                            cursor: pointer;
                            white-space: nowrap;
                            transition: background 0.15s, transform 0.1s;
                            flex-shrink: 0;
                        }

                            #pwaInstallBanner .pwa-install-btn:hover {
                                background: #0b5ed7;
                                transform: scale(1.04);
                            }

                        #pwaInstallBanner .pwa-close-btn {
                            background: none;
                            border: none;
                            color: rgba(255,255,255,0.45);
                            cursor: pointer;
                            padding: 4px;
                            font-size: 1rem;
                            line-height: 1;
                            flex-shrink: 0;
                            transition: color 0.15s;
                        }

                            #pwaInstallBanner .pwa-close-btn:hover {
                                color: rgba(255,255,255,0.85);
                            }

                    @@media (max-width: 400px) {
                        #pwaInstallBanner {
                            bottom: 16px;
                            padding: 12px 14px;
                            gap: 10px;
                        }
                    }
            </style>
        </head>
        <body class="d-flex flex-column min-vh-100">
            <header>
                <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top">
                    <div class="container">

                        <!-- ? Brand -->
                        <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-tools me-1"></i>HandyGo
