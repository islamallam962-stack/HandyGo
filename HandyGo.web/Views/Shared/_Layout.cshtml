                                                <li><a class="dropdown-item" asp-controller="Offers" asp-action="Index">Approved Orders</a></li>
                                                <li><a class="dropdown-item" asp-controller="OffersPrice" asp-action="MyPublicRequests">Open Requests</a></li>
                                            }

                                            @if (userRole == "Technician")
                                            {
                                                <li><a class="dropdown-item" asp-controller="TechnicianRequests" asp-action="OpenJobs">Marketplace</a></li>
                                                <li><a class="dropdown-item" asp-controller="TechnicianRequests" asp-action="Index">Available Jobs</a></li>
                                            }

                                            @if (userRole == "Admin")
                                            {
                                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 text-primary me-2"></i> áćÍÉ ÇáŢíÇĎÉ</a></li>
                                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Financials"><i class="bi bi-bank text-success me-2"></i> ÇáĹĎÇŃÉ ÇáăÇáíÉ</a></li>
                                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="FinancialDisputes"><i class="bi bi-cash-stack text-danger me-2"></i> ÇáäŇÇÚÇĘ ÇáăÇáíÉ</a></li>
                                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Affiliates"><i class="bi bi-diagram-3-fill text-primary me-2"></i> ăĘÇČÚÉ ÇáăÓćŢíä</a></li>
                                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Verifications"><i class="bi bi-shield-check text-primary me-2"></i> ăŃßŇ ÇáĘćËíŢ</a></li>
                                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="PromoCodes"><i class="bi bi-ticket-perforated text-primary me-2"></i> ĹĎÇŃÉ ÇáßćČćäÇĘ</a></li>
                                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users"><i class="bi bi-people text-secondary me-2"></i> Control System</a></li>
                                            }
                                        </ul>
                                    </li>
