                                <li class="nav-item"><a class="nav-link" href="/Home#help">Help</a></li>
                            </ul>

                            <!-- User controls -->
                            <div class="user-controls d-flex align-items-center gap-2">
                                @if (userId != null)
                                {
                                    <a asp-controller="Wallet" asp-action="Index"
                                           class="btn btn-outline-success btn-sm wallet-btn fw-bold shadow-sm"
                                           title="ăÍÝŮĘí">
                                        <i class="bi bi-wallet2 me-1"></i> @currentWalletBalance.ToString("0.00") Ě.ă
                                    </a>

                                    <span class="user-badge">Hi, @userName</span>

                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline w-100 w-lg-auto">
