@model IEnumerable<HandyGo.web.Models.Request>

<div class="container mt-5 pt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 rounded-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4 rounded-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-white py-4 border-0">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="fw-bold mb-1">
                        <i class="bi bi-stack text-primary me-2"></i> My Open Requests
                    </h3>
                    <p class="text-muted mb-0 small">Track your public requests and manage technician offers in real-time.</p>
                </div>
                <div class="col-auto d-flex gap-2 flex-wrap justify-content-end">
                    <a asp-controller="Profile" asp-action="Index" onclick="localStorage.setItem('activeTab', 'requestsTab');" class="btn btn-outline-secondary rounded-pill px-4 fw-bold">
                        <i class="bi bi-arrow-left me-1"></i> Back
                    </a>

                    
                    <a asp-controller="RequestServices" asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold">
                        <i class="bi bi-plus-lg me-1"></i> New Request
                    </a>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">Service Type</th>
                        <th class="py-3">Posted Date</th>
                        <th class="py-3">Location</th>
                        <th class="py-3 text-center">Status & Offers</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
                                <p class="text-muted fw-bold">No open requests found.</p>
                                <a asp-controller="RequestServices" asp-action="Create" class="btn btn-outline-primary btn-sm rounded-pill">Post your first request</a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-box bg-primary-soft rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: rgba(0,97,242,0.1);">
                                            <i class="bi bi-tools text-primary"></i>
                                        </div>
                                        <span class="fw-bold text-dark">@item.ServiceType</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-muted small">
                                        <i class="bi bi-calendar3 me-1"></i> @item.CreatedAt.ToString("dd MMM yyyy")
                                    </span>
                                </td>
                                <td>
                                    <span class="text-muted small">
                                        <i class="bi bi-geo-alt-fill text-danger me-1"></i> @item.Address
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex flex-column align-items-center gap-1">
                                        <span class="badge rounded-pill bg-success px-3">Active</span>
                                        <span class="badge rounded-pill bg-info text-dark border shadow-sm">
                                            @item.Bids.Count Offers
                                        </span>
                                    </div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                        
                                        <a asp-action="RequestOffers" asp-route-requestId="@item.Id" class="btn btn-primary btn-sm px-3">
                                            <i class="bi bi-eye-fill"></i> View
                                        </a>
                                        <button type="button" class="btn btn-danger btn-sm px-3" onclick="confirmCancel('@item.Id')">
                                            <i class="bi bi-x-circle"></i> Cancel
                                        </button>
                                    </div>

                                    <form id="cancel-form-@item.Id" asp-action="CancelRequest" method="post" class="d-none">
                                        <input type="hidden" name="requestId" value="@item.Id" />
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmCancel(id) {
            if (confirm('Are you sure you want to cancel this request entirely?')) {
                document.getElementById('cancel-form-' + id).submit();
            }
        }
    </script>
}
