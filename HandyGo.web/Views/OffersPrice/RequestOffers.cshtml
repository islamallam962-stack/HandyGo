@model HandyGo.web.Models.Request

<style>
    .offer-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 15px;
    }

        .offer-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .tech-img {
        transition: scale 0.3s ease;
    }

    .offer-card:hover .tech-img {
        scale: 1.05;
    }

    .service-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-left: 5px solid #0061f2;
    }
</style>

<div class="container mt-5 pt-3">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 rounded-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4 rounded-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card service-header border-0 shadow-sm mb-5 rounded-4">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h2 class="fw-bold text-dark mb-2">
                        <i class="bi bi-tools text-primary me-2"></i> @Model.ServiceType
                    </h2>
                    <p class="mb-1 text-secondary">
                        <i class="bi bi-geo-alt-fill text-danger me-1"></i> <strong>Address:</strong> @Model.Address
                    </p>
                    <p class="text-muted small mb-0">
                        <i class="bi bi-clock-history me-1"></i> Posted on: @Model.CreatedAt.ToString("f")
                    </p>
                </div>
                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                    <span class="badge bg-primary rounded-pill px-4 py-2 fs-6 shadow-sm">
                        @Model.Bids.Count Available Offers
                    </span>
                    <a asp-controller="Profile" asp-action="Index" onclick="localStorage.setItem('activeTab', 'requestsTab');" class="btn btn-outline-secondary btn-sm mt-3 d-block rounded-pill">
                        <i class="bi bi-arrow-left me-1"></i> Back to My Requests
                    </a>
                </div>
            </div>
        </div>
    </div>

    <h4 class="fw-bold mb-4">Choose the Best Offer</h4>

    <div class="row">
        @if (!Model.Bids.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="alert shadow-sm border-0 rounded-4 py-5" style="background-color: #fff;">
                    <i class="bi bi-hourglass-split display-4 text-primary mb-3"></i>
                    <h5 class="fw-bold">No technicians have sent offers yet.</h5>
                    <p class="text-muted">We'll notify you as soon as someone bids on your request.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var bid in Model.Bids)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 offer-card">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-4">
                                <div class="position-relative">
                                    <img src="@(string.IsNullOrEmpty(bid.Technician.ImagePath) ? "/images/default.png" : bid.Technician.ImagePath)"
                                         class="rounded-circle border border-3 border-white shadow-sm tech-img"
                                         style="width: 70px; height: 70px; object-fit: cover;"
                                         alt="@bid.Technician.Name">
                                    <span class="position-absolute bottom-0 end-0 bg-success border border-2 border-white rounded-circle" style="width: 15px; height: 15px;"></span>
                                </div>

                                <div class="ms-3">
                                    <h6 class="mb-1 fw-bold">
                                        <a asp-controller="Profile" asp-action="Details" asp-route-id="@bid.TechnicianId"
                                           class="text-dark text-decoration-none">
                                            @bid.Technician.Name
                                        </a>
                                    </h6>
                                    <div class="text-warning small d-flex align-items-center">
                                        @{
                                            var avgRating = bid.Technician.ReceivedReviews != null && bid.Technician.ReceivedReviews.Any()
                                            ? bid.Technician.ReceivedReviews.Average(r => r.Stars)
                                            : 0;

                                            for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi @(i <= Math.Round(avgRating) ? "bi-star-fill" : "bi-star") me-1"></i>
                                            }
                                        }
                                        <span class="text-muted ms-2">(@bid.Technician.ReceivedReviews?.Count())</span>
                                    </div>
                                </div>
                            </div>

                            <div class="rounded-4 p-3 mb-4" style="background-color: #f8faff; border: 1px solid #edf2f7;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-muted small fw-bold text-uppercase">Proposed Price</span>
                                    <span class="text-success fw-bold fs-5">@bid.Price EGP</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted small fw-bold text-uppercase">Arrival Time</span>
                                    <span class="text-dark fw-bold small"><i class="bi bi-lightning-charge-fill text-warning me-1"></i> @bid.EstimatedTime</span>
                                </div>
                                @if (!string.IsNullOrEmpty(bid.Note))
                                {
                                    <hr class="my-2 opacity-25">
                                    <p class="mb-0 small text-secondary italic">
                                        <i class="bi bi-chat-left-text me-1"></i> "@bid.Note"
                                    </p>
                                }
                            </div>

                            <div class="row g-2">
                                <div class="col-8">
                                    <form asp-action="AcceptBid" method="post" onsubmit="return confirm('Are you sure you want to accept this offer?');">
                                        <input type="hidden" name="bidId" value="@bid.Id" />
                                        <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2 shadow-sm">
                                            Accept Offer
                                        </button>
                                    </form>
                                </div>
                                <div class="col-4">
                                    <form asp-action="RejectBid" method="post" onsubmit="return confirm('Are you sure you want to reject this offer?');">
                                        <input type="hidden" name="bidId" value="@bid.Id" />
                                        <button type="submit" class="btn btn-outline-light text-danger border-0 w-100 rounded-pill fw-bold py-2">
                                            Reject
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
